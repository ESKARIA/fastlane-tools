# frozen_string_literal: true

require 'fileutils'

# Гарантирует наличие dSYM-артефакта в DSYM_FOLDER_PATH после сборки.
#
# Зачем: gym (build_app) НЕ всегда кладёт `<name>.app.dSYM.zip` рядом с IPA —
# особенно для extension-схем (iMessage), где dSYM лежат внутри .xcarchive, но
# gym их не зипует. Тогда `copy_artifacts(... '*.dSYM.zip' ...)` копирует пустоту
# и стадия upload_dsyms не находит символы. Здесь, если в DSYM_FOLDER_PATH пусто,
# достаём dSYM напрямую: сначала из gym DSYM_OUTPUT_PATH, затем из dSYMs архива,
# затем из DerivedData — и зипуем в DSYM_FILE_PATH.
def ensure_dsym_artifact
  require 'tmpdir'
  require 'shellwords'

  dsym_dir = File.expand_path(DSYM_FOLDER_PATH)
  FileUtils.mkdir_p(dsym_dir)

  existing = Dir.glob(File.join(dsym_dir, '*.dSYM.zip'))
  unless existing.empty?
    UI.message("✅ dSYM-артефакт уже на месте (#{existing.size} шт.) — фоллбэк не нужен")
    return
  end

  UI.important('⚠️  dSYM.zip не попал в артефакты от gym — достаём dSYM вручную')

  out_zip = expand_under_project_root(DSYM_FILE_PATH)

  # 1) gym мог сделать zip и записать путь в lane_context.
  #    ВАЖНО: пути из lane_context/DERIVED_PATH относительные — резолвим их
  #    относительно КОРНЯ проекта, а не cwd (у fastlane cwd = папка fastlane/),
  #    иначе архив и DerivedData ищутся в несуществующем …/fastlane/build.
  gym_zip = begin
    lane_context[SharedValues::DSYM_OUTPUT_PATH]
  rescue StandardError
    nil
  end
  gym_zip = expand_under_project_root(gym_zip) if gym_zip
  if gym_zip && File.exist?(gym_zip)
    FileUtils.cp(gym_zip, out_zip)
    UI.success("✅ dSYM скопирован из gym DSYM_OUTPUT_PATH: #{gym_zip}")
    return
  end

  # 2) Ищем *.dSYM в архиве сборки, затем — в DerivedData.
  archive = begin
    lane_context[SharedValues::XCODEBUILD_ARCHIVE]
  rescue StandardError
    nil
  end
  archive = expand_under_project_root(archive) if archive
  dsym_sources = []
  dsym_sources = Dir.glob(File.join(archive, 'dSYMs', '*.dSYM')) if archive && Dir.exist?(File.join(archive, 'dSYMs'))
  dsym_sources = Dir.glob(File.join(expand_under_project_root(DERIVED_PATH), '**', '*.dSYM')) if dsym_sources.empty?

  if dsym_sources.empty?
    UI.important('⚠️  Не найдено ни одного *.dSYM (ни в архиве, ни в DerivedData).')
    UI.important('   Проверьте, что для Release задан DEBUG_INFORMATION_FORMAT = dwarf-with-dsym.')
    return
  end

  UI.message("Найдено dSYM: #{dsym_sources.size}. Зипуем в #{out_zip}")
  dsym_sources.each { |d| UI.message("  • #{d}") }

  # Стейджим все .dSYM в temp и зипуем их как top-level записи (без абсолютных путей).
  Dir.mktmpdir('dsyms') do |staging|
    dsym_sources.uniq { |d| File.basename(d) }.each { |d| FileUtils.cp_r(d, staging) }
    FileUtils.rm_f(out_zip)
    Dir.chdir(staging) { sh("zip -r -q #{out_zip.shellescape} .") }
  end
  UI.success("✅ dSYM собран вручную: #{out_zip}")
end

# ==============================================================================
# Fastfile_build - Сборка iOS приложений
# ==============================================================================
# Этот модуль содержит lanes для сборки iOS приложений в формате IPA
# для публикации в App Store через TestFlight.
#
# Основные функции:
#   - Установка маркетинговой версии приложения
#   - Сборка IPA файлов с подписью для App Store
#   - Управление build numbers
#   - Сохранение артефактов сборки (IPA и dSYM)
# ==============================================================================

# ==============================================================================
# KEYCHAIN ДЛЯ ПОДПИСИ
# ==============================================================================

# Имя и пароль keychain для подписи. Пустой пароль — стандарт для CI.
SIGNING_KEYCHAIN_NAME     = ENV['MATCH_KEYCHAIN_NAME'] || 'fastlane_tmp_keychain'
SIGNING_KEYCHAIN_PASSWORD = ENV['MATCH_KEYCHAIN_PASSWORD'] || ''

# Гарантирует наличие разблокированного keychain для подписи.
#
# Идемпотентно: если keychain есть — разблокирует, если нет — создаёт.
# Keychain создаётся БЕЗ таймаута и БЕЗ блокировки при сне, поэтому не лочится
# посреди длинной сборки (корневая причина GUI-запроса пароля). Не делаем его
# системным default, чтобы не трогать login.keychain живого пользователя —
# match/gym получают keychain явно через ENV[MATCH_KEYCHAIN_NAME].
#
# Заменяет setup_ci (который создавал keychain с timeout: 3600 и
# lock_when_sleeps: true) и снимает необходимость постоянно его удалять.
def ensure_signing_keychain
  name           = SIGNING_KEYCHAIN_NAME
  password       = SIGNING_KEYCHAIN_PASSWORD
  keychain_path  = File.expand_path("~/Library/Keychains/#{name}-db")

  if File.exist?(keychain_path)
    UI.message("Keychain '#{name}' уже существует — разблокирую")
    unlock_keychain(path: name, password: password)
  else
    UI.message("Keychain '#{name}' не найден — создаю")
    create_keychain(
      name: name,
      password: password,
      default_keychain: false,   # не трогаем системный default
      unlock: true,
      timeout: 0,                # без авто-блокировки по таймауту
      lock_when_sleeps: false,   # не блокировать при сне
      add_to_search_list: true
    )
  end

  # На случай ранее созданного keychain принудительно снимаем авто-лок
  # (no timeout + no lock-on-sleep): security set-keychain-settings без -t/-l.
  sh("security set-keychain-settings #{keychain_path}")

  # Сообщаем match/gym, какой keychain использовать.
  ENV['MATCH_KEYCHAIN_NAME']     = name
  ENV['MATCH_KEYCHAIN_PASSWORD'] = password
end

# ==============================================================================
# ХЕЛПЕРЫ ДЛЯ РАБОТЫ С ВЕРСИЯМИ
# ==============================================================================

# Проверяет, существует ли Info.plist для указанного таргета
# @param target [String] название таргета
# @param xcodeproj [String] путь к .xcodeproj файлу
# @return [Boolean] true если Info.plist найден
def info_plist_exists?(target:, xcodeproj:)
  # Используем get_info_plist_path из fastlane-plugin-versioning
  plist_path = get_info_plist_path(
    xcodeproj: xcodeproj,
    target: target
  )

  # Проверяем, что путь не nil и не пустой
  if plist_path.nil? || plist_path.to_s.strip.empty?
    UI.message("📋 Info.plist для таргета '#{target}': не найден (путь пустой)")
    return false
  end

  # Проверяем существование файла
  exists = File.exist?(plist_path)
  UI.message("📋 Info.plist для таргета '#{target}': #{exists ? 'найден' : 'не найден'} по пути #{plist_path}")
  exists
rescue StandardError => e
  UI.message("⚠️  Не удалось получить путь к Info.plist для '#{target}': #{e.class} - #{e.message}")
  false
end

# Устанавливает версию для конкретного таргета
# Автоматически определяет, нужно ли обновлять Info.plist
# @param target [String] название таргета
# @param version [String] маркетинговая версия
# @param build [Integer, nil] номер сборки (опционально)
def set_version_for_target(target:, version:, build: nil)
  xcodeproj = ENV['MAIN_PROJECT_FILE']

  UI.message("📦 Устанавливаю версию для таргета '#{target}'")
  UI.message("   MARKETING_VERSION: #{version}")
  UI.message("   CURRENT_PROJECT_VERSION: #{build}") if build

  # 1. ВСЕГДА обновляем xcodeproj (это основной источник правды в новых Xcode)
  increment_version_number_in_xcodeproj(
    version_number: version.to_s,
    target: target,
    xcodeproj: xcodeproj
  )
  increment_build_number_in_xcodeproj(
    build_number: BUILD_NUMBER.to_s,
    target: target,
    xcodeproj: xcodeproj
  )

  # 2. ОБНОВЛЯЕМ Info.plist ТОЛЬКО если он существует (для обратной совместимости)
  if info_plist_exists?(target: target, xcodeproj: xcodeproj)
    UI.message('   📝 Обновляю Info.plist (старый формат проекта)')

    increment_version_number_in_plist(
      version_number: version.to_s,
      target: target,
      xcodeproj: xcodeproj
    )

    if build
      increment_build_number_in_plist(
        build_number: BUILD_NUMBER.to_s,
        target: target,
        xcodeproj: xcodeproj
      )
    end
  else
    UI.message('   ⏭️  Пропускаю Info.plist (новый формат Xcode 14+)')
  end
end

# Синхронизирует CURRENT_PROJECT_VERSION остальных таргетов проекта (расширения,
# watch app, tests) с build number главного таргета.
#
# Зачем: set_version_for_target бампит build number ТОЛЬКО для MAIN_TARGET.
# Если в проекте есть встроенные таргеты (widget extension, watch app), их
# CURRENT_PROJECT_VERSION остаётся на исходном значении (обычно "1") навсегда,
# а у главного приложения растёт с каждой сборкой. Apple при архивации/экспорте
# требует совпадения CFBundleVersion расширения и содержащего его приложения —
# рассинхрон приводит к сбою IDEDistributionMethodManager внутри Xcode и
# необъяснимому `exportOptionsPlist error for key "method" expected one {}`,
# хотя сам plist корректен.
def sync_build_number_for_other_targets(xcodeproj:, main_target:, build:)
  require 'xcodeproj'

  # Xcodeproj (обычный Ruby-код) резолвит относительные пути через Dir.pwd,
  # который у fastlane равен папке fastlane/, а не корню проекта — приводим
  # к абсолютному пути так же, как это делает ensure_dsym_artifact.
  project = Xcodeproj::Project.open(expand_under_project_root(xcodeproj))
  project.targets.each do |target|
    next if target.name == main_target

    target.build_configurations.each do |config|
      config.build_settings['CURRENT_PROJECT_VERSION'] = build.to_s
    end
    UI.message("   🔄 CURRENT_PROJECT_VERSION таргета '#{target.name}' синхронизирован на #{build}")
  end
  project.save
end

# ==============================================================================
# LANES
# ==============================================================================

# Устанавливает маркетинговую версию приложения
#
# Обновляет версию приложения в:
#   - Настройках сборки проекта (xcodeproj) — ВСЕГДА
#   - Info.plist файле — ТОЛЬКО если он существует (для старых проектов)
#
# Требует переменную окружения: APP_VERSION
#
# @example
#   export APP_VERSION="1.2.3"
#   export MAIN_TARGET="MyApp"
#   fastlane version
desc 'Set new marketing version'
lane :version do |_options|
  UI.user_error!('❌ APP_VERSION не установлен') if ENV['APP_VERSION'].to_s.empty?
  UI.user_error!('❌ MAIN_TARGET не установлен') if MAIN_TARGET.to_s.empty?

  version_to_set = ENV['APP_VERSION'].to_s
  target_name = MAIN_TARGET.to_s

  UI.header("Установка версии #{version_to_set} для таргета '#{target_name}'")

  set_version_for_target(
    target: target_name,
    version: version_to_set
  )

  UI.success('✅ Версия установлена успешно')
end

# Собирает IPA файл для App Store
#
# Полный процесс сборки:
#   1. Валидация обязательных переменных окружения
#   2. Создание директорий для артефактов
#   3. Установка маркетинговой версии (с проверкой Info.plist)
#   4. Настройка API ключа App Store Connect
#   5. Инкрементирование build number (с проверкой Info.plist)
#   6. Установка App Store сертификатов через match
#   7. Сборка приложения с подписью для App Store
#   8. Сохранение артефактов (IPA и dSYM)
#
# Требует переменные окружения:
#   - APP_VERSION: маркетинговая версия (например, "1.2.3")
#   - CI_PIPELINE_IID или BUILD_NUMBER: номер сборки
#   - APP_IDENTIFIER: bundle identifier приложения
#   - MAIN_TARGET: название target для сборки
#   - APPSTORE_KEY_ID, APPSTORE_ISSUER_ID, APPSTORE_KEY_CONTENT: API ключи
#
# Результат:
#   - IPA файл: fastlane/artifacts/{TARGET}_v{VERSION}_b{BUILD}.ipa
#   - dSYM файл: fastlane/artifacts/{TARGET}_v{VERSION}_b{BUILD}.app.dSYM.zip
#   - Лежат плоско в рабочей директории проекта; между job-ами передаются через
#     механизм CI-артефактов (без выноса в ~/.cache)
#
# @example
#   export APP_VERSION="1.2.3"
#   export CI_PIPELINE_IID="456"
#   export MAIN_TARGET="BearOliver"
#   fastlane build
desc 'Build project'
lane :build do |options|
  # Проверка и установка файла проекта по умолчанию
  check_and_set_project_file

  # Начало сбора метрик (если helpers доступны)
  start_metrics('build') if respond_to?(:start_metrics)

  # ========================================================================
  # ВАЛИДАЦИЯ ОБЯЗАТЕЛЬНЫХ ПЕРЕМЕННЫХ ОКРУЖЕНИЯ
  # ========================================================================
  UI.user_error!('❌ APP_VERSION не установлен') if ENV['APP_VERSION'].nil? || ENV['APP_VERSION'].empty?
  UI.user_error!('❌ BUILD_NUMBER не установлен') if BUILD_NUMBER.nil? || BUILD_NUMBER.to_s.empty?
  UI.user_error!('❌ MAIN_TARGET не установлен') if MAIN_TARGET.to_s.empty?

  # Добавление метрик о версии и build number
  add_metric('version', ENV['APP_VERSION']) if respond_to?(:add_metric)
  add_metric('build_number', BUILD_NUMBER.to_s) if respond_to?(:add_metric)

  # Отправка уведомления о начале сборки в Telegram (если включено)
  if ENV['TELEGRAM_ENABLED'] == 'true' && respond_to?(:notify_telegram_stage)
    notify_telegram_stage('Начало сборки приложения', {
                            'Версия' => ENV['APP_VERSION'],
                            'Build' => BUILD_NUMBER.to_s,
                            'Target' => MAIN_TARGET.to_s,
                            'Scheme' => BUILD_SCHEME.to_s,
                            'Configuration' => BUILD_CONFIGURATION.to_s.empty? ? 'из схемы' : BUILD_CONFIGURATION.to_s
                          })
  end

  # ========================================================================
  # ПОДГОТОВКА ОКРУЖЕНИЯ
  # ========================================================================
  FileUtils.mkdir_p(File.expand_path(IPA_FOLDER_PATH))
  FileUtils.mkdir_p(File.expand_path(DSYM_FOLDER_PATH))

  # ========================================================================
  # УПРАВЛЕНИЕ ВЕРСИЯМИ (С ПРОВЕРКОЙ INFO.PLIST)
  # ========================================================================
  # Устанавливаем версию ТОЛЬКО для конкретного таргета
  # Автоматически определяет, нужен ли Info.plist
  set_version_for_target(
    target: MAIN_TARGET.to_s,
    version: ENV['APP_VERSION'].to_s,
    build: BUILD_NUMBER.to_i
  )

  # Держим встроенные таргеты (расширения, watch app) в синхроне по build number —
  # иначе Apple отклоняет архив/экспорт из-за рассинхрона CFBundleVersion.
  sync_build_number_for_other_targets(
    xcodeproj: ENV['MAIN_PROJECT_FILE'],
    main_target: MAIN_TARGET.to_s,
    build: BUILD_NUMBER.to_i
  )

  # Получение текущей маркетинговой версии из проекта
  # ИСПОЛЬЗУЕМ actions из fastlane-plugin-versioning (поддерживают target)
  version_number = get_version_number_from_xcodeproj(
    xcodeproj: ENV['MAIN_PROJECT_FILE'],
    target: MAIN_TARGET
  )

  build_number = get_build_number_from_xcodeproj(
    xcodeproj: ENV['MAIN_PROJECT_FILE'],
    target: MAIN_TARGET
  )

  # Вывод информации о версии и номере сборки
  UI.header('Сборка приложения')
  UI.message("Версия: #{version_number}")
  UI.message("Номер сборки: #{build_number}")
  UI.message("Target: #{MAIN_TARGET}")
  UI.message("Scheme: #{BUILD_SCHEME}")
  UI.message("Configuration: #{BUILD_CONFIGURATION.to_s.empty? ? 'из схемы' : BUILD_CONFIGURATION}")

  # ========================================================================
  # НАСТРОЙКА API КЛЮЧА APP STORE CONNECT
  # ========================================================================
  app_store_connect_api_key(
    key_id: APPSTORE_KEY_ID,
    issuer_id: APPSTORE_ISSUER_ID,
    key_content: APPSTORE_KEY_CONTENT,
    in_house: false,
    is_key_content_base64: true
  )

  # ========================================================================
  # УСТАНОВКА СЕРТИФИКАТОВ
  # ========================================================================
  ensure_signing_keychain
  match_install_appstore(options)

  # ========================================================================
  # СБОРКА ПРИЛОЖЕНИЯ
  # ========================================================================
  app_identifiers = respond_to?(:get_all_app_identifiers) ? get_all_app_identifiers : APP_IDENTIFIER.to_s.split(',').map(&:strip).reject(&:empty?)
  UI.user_error!('❌ APP_IDENTIFIER не установлен или пуст') if app_identifiers.empty?

  UI.message("Найдено bundle identifiers: #{app_identifiers.count}")
  app_identifiers.each_with_index do |identifier, index|
    UI.message("  #{index + 1}. #{identifier}")
  end

  provisioning_profiles = app_identifiers.each_with_object({}) do |identifier, hash|
    hash[identifier] = "match AppStore #{identifier}"
  end

  # ВАЖНО: НЕ используем xcargs с MARKETING_VERSION, т.к. мы уже записали
  # версию в xcodeproj для конкретного таргета. Иначе xcargs перезапишет
  # версии ВСЕХ таргетов одним значением.
  build_params = {
    project: ENV['MAIN_PROJECT_FILE'],
    scheme: BUILD_SCHEME,
    export_options: {
      provisioningProfiles: provisioning_profiles,
      signingStyle: 'manual'
    },
    cloned_source_packages_path: 'SourcePackages',
    clean: true,
    output_name: IPA_FILE_NAME.to_s,
    build_path: DERIVED_PATH.to_s
    # ❌ xcargs с MARKETING_VERSION УБРАН
  }
  build_params[:configuration] = BUILD_CONFIGURATION unless BUILD_CONFIGURATION.to_s.empty?

  build_app(**build_params)

  # ========================================================================
  # СОХРАНЕНИЕ АРТЕФАКТОВ
  # ========================================================================
  # IPA и dSYM кладём плоско в ARTIFACTS_PATH (по умолчанию fastlane/artifacts/).
  # Это единственное каноническое место хранения; именно его (плоским глобом
  # *.ipa / *.dSYM.zip) передаёт механизм CI-артефактов между job-ами.
  copy_artifacts(target_path: IPA_FOLDER_PATH.to_s, artifacts: ['*.ipa', IPA_FILE_PATH.to_s])
  copy_artifacts(target_path: DSYM_FOLDER_PATH.to_s, artifacts: ['*.dSYM.zip', DSYM_FILE_PATH.to_s])

  # gym для extension-схем часто не зипует dSYM — гарантируем артефакт вручную.
  ensure_dsym_artifact

  # Дополнительная копия в repo-local fastlane/artifacts/ нужна ТОЛЬКО когда
  # ARTIFACTS_PATH вынесен за пределы рабочей копии (напр. ~/.cache): иначе
  # CI-артефакты и find_ipa_files('artifacts') не увидят сборку. Если ARTIFACTS_PATH
  # уже внутри fastlane/artifacts/ (дефолт) — копия избыточна и создаёт дубли
  # IPA/dSYM (двойная заливка в TestFlight, раздутый артефакт), поэтому пропускаем.
  ci_artifacts_dir = File.expand_path('fastlane/artifacts', fastlane_tools_project_root)
  unless File.expand_path(ARTIFACTS_PATH.to_s).start_with?(ci_artifacts_dir)
    copy_artifacts(target_path: 'fastlane/artifacts/', artifacts: ['*.dSYM.zip', '*.ipa'])
  end

  # ========================================================================
  # ВАЛИДАЦИЯ АРТЕФАКТОВ
  # ========================================================================
  expanded_ipa_path = File.expand_path(IPA_FILE_PATH)
  expanded_dsym_path = File.expand_path(DSYM_FILE_PATH)

  possible_ipa_paths = [
    expanded_ipa_path,
    File.join(Dir.pwd, IPA_FILE_NAME),
    File.join(DERIVED_PATH, IPA_FILE_NAME),
    File.join('fastlane/artifacts', IPA_FILE_NAME)
  ].map { |p| File.expand_path(p) }.uniq

  found_ipa_path = possible_ipa_paths.find { |path| File.exist?(path) }

  unless found_ipa_path
    UI.user_error!("❌ IPA файл не найден после сборки. Проверялись пути:\n  - #{possible_ipa_paths.join("\n  - ")}")
  end

  expanded_ipa_path = found_ipa_path
  UI.message("✅ Найден IPA файл: #{expanded_ipa_path}")

  unless File.exist?(expanded_dsym_path)
    possible_dsym_paths = [
      expanded_dsym_path,
      File.join(Dir.pwd, DSYM_FILE_NAME),
      File.join(DERIVED_PATH, DSYM_FILE_NAME),
      File.join('fastlane/artifacts', DSYM_FILE_NAME)
    ].map { |p| File.expand_path(p) }.uniq

    found_dsym_path = possible_dsym_paths.find { |path| File.exist?(path) }

    if found_dsym_path
      expanded_dsym_path = found_dsym_path
      UI.message("✅ Найден dSYM файл: #{expanded_dsym_path}")
    else
      UI.important('⚠️  dSYM файл не найден. Проверялись пути:')
      possible_dsym_paths.each { |p| UI.important("  - #{p}") }
      UI.important('Это не критично, но может затруднить отладку крашей')
    end
  end

  # ========================================================================
  # ПРОВЕРКА РАЗМЕРОВ
  # ========================================================================
  ipa_size_mb = File.size(expanded_ipa_path) / (1024.0 * 1024.0)
  ipa_size_gb = ipa_size_mb / 1024.0

  if ipa_size_gb > 4.0
    UI.user_error!("❌ IPA файл слишком большой: #{ipa_size_gb.round(2)}GB (лимит App Store: 4GB)")
  elsif ipa_size_gb > 3.5
    UI.important("⚠️  IPA файл близок к лимиту: #{ipa_size_gb.round(2)}GB")
  end

  # ========================================================================
  # ЗАВЕРШЕНИЕ СБОРКИ
  # ========================================================================
  UI.success('✅ Сборка завершена успешно')
  UI.message("IPA: #{expanded_ipa_path}")
  UI.message("Размер IPA: #{ipa_size_mb.round(2)}MB (#{ipa_size_gb.round(3)}GB)")
  UI.message("dSYM: #{expanded_dsym_path}")

  if File.exist?(expanded_dsym_path)
    dsym_size_mb = File.size(expanded_dsym_path) / (1024.0 * 1024.0)
    UI.message("Размер dSYM: #{dsym_size_mb.round(2)}MB")
    add_metric('dsym_size_mb', dsym_size_mb.round(2)) if respond_to?(:add_metric)
  end

  add_metric('ipa_size_mb', ipa_size_mb.round(2)) if respond_to?(:add_metric)
  add_metric('ipa_size_gb', ipa_size_gb.round(3)) if respond_to?(:add_metric)
  add_metric('status', 'success') if respond_to?(:add_metric)

  if ENV['TELEGRAM_ENABLED'] == 'true' && respond_to?(:notify_telegram_success)
    notify_telegram_success('Сборка завершена успешно', {
                              'Версия' => version_number,
                              'Build' => build_number.to_s,
                              'Target' => MAIN_TARGET.to_s,
                              'Scheme' => BUILD_SCHEME.to_s,
                              'Configuration' => BUILD_CONFIGURATION.to_s.empty? ? 'из схемы' : BUILD_CONFIGURATION.to_s,
                              'Размер IPA' => "#{ipa_size_mb.round(2)}MB (#{ipa_size_gb.round(3)}GB)",
                              'IPA файл' => File.basename(expanded_ipa_path),
                              'dSYM' => File.exist?(expanded_dsym_path) ? File.basename(expanded_dsym_path) : 'не найден'
                            }, include_metrics: true)
  end
end
