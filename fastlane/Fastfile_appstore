lane :auto_release_branch do |options|
  raise 'Has no APPSTORE_KEY_CONTENT' unless APPSTORE_KEY_CONTENT

  app_store_connect_api_key(key_id: APPSTORE_KEY_ID,
                            issuer_id: APPSTORE_ISSUER_ID,
                            key_content: APPSTORE_KEY_CONTENT,
                            in_house: false,
                            is_key_content_base64: true)

  check_and_set_project_file
  branch_name = git_branch
  minimal_version = options[:minimal_version] || '1.0.0'

  UI.message("Текущая ветка: #{branch_name}")

  # 2. Проверяем сборки в бете и релизе
  beta_version = beta_version_number # Здесь нужно будет добавить функцию для получения версии из беты
  release_version = release_version_number # Функция для получения версии из релиза

  # 3. Сравниваем версии
  highest_version = [beta_version, release_version].max
  UI.message("Старшая версия: #{highest_version}")

  if Gem::Version.new(highest_version) < Gem::Version.new(minimal_version)
    UI.message("Текущая версия #{highest_version} меньше минимальной версии #{minimal_version}. Устанавливаем версию на минимальную.")
    highest_version = minimal_version
  end

  version = highest_version
  version = increment_patch_version(highest_version) if highest_version == release_version

  # Синхронизируем локальные и удалённые ветки, удаляя несуществующие
  sh('git fetch --prune origin')

  # Название ветки для проверки
  release_branch_name = "release/#{version}"

  # Проверяем, существует ли ветка
  branch_exists = sh("git branch --list #{release_branch_name}").strip

  # # Если ветка не существует, создаем её
  # sh("git branch #{branch_name}") if branch_exists.empty?

  sh("echo \"VERSION=#{version}, TIMESTAMP=$(date '+%Y-%m-%d %H:%M:%S')\" >> last_update.txt")
  update_metadata_year(options)
  sh("git add '*.txt' && git add '**/*.txt'") # Добавляем все файлы .txt включая вложенные в папках в staged

  # git_commit(path: ['./*.txt'], message: 'Version Update for release') # Коммитим изменения
  sh("git commit -m 'Version Update for release'")

  increment_version_number(version_number: highest_version.to_s)

  # # 4. Действия для релизной версии
  if highest_version == release_version
    # Собираем с повышением патч версии
    increment_version_number(bump_type: 'patch')
  end

  version_number = get_version_number(xcodeproj: ENV['MAIN_PROJECT_FILE'], target: MAIN_TARGET)

  # push_to_git_remote(local_branch: branch_name, remote_branch: branch_name, force: true)
  push_to_git_remote(local_branch: branch_name, remote_branch: "release/#{version_number}", force: true)

  UI.message("Старшая версия: #{version_number}")
end

desc 'Check if marketing version is released on the App Store and write release_status.json'
lane :check_released do |options|
  require 'json'
  require 'time'
  require 'spaceship'

  version_string = options[:ver] || ENV['APP_VERSION']
  identifiers = respond_to?(:get_all_app_identifiers) ? get_all_app_identifiers : APP_IDENTIFIER.to_s.split(',').map(&:strip).reject(&:empty?)
  app_identifier = identifiers.first

  status = {
    app_identifier: app_identifier,
    version: version_string.to_s,
    released: false,
    state: nil,
    timestamp: Time.now.utc.iso8601
  }

  begin
    if version_string.to_s.strip.empty?
      status[:error] = 'Параметр ver не указан (пример: fastlane check_released ver:2.8.3)'
      UI.important(status[:error])
      next status
    end

    if app_identifier.nil? || app_identifier.empty?
      status[:error] = 'APP_IDENTIFIER не указан'
      UI.important(status[:error])
      next status
    end

    UI.header("Проверка релиза #{version_string} для #{app_identifier}")

    api_key = prepare_api_key_for_release_check

    unless api_key
      status[:error] = 'Не удалось настроить App Store Connect API ключ. Установите APPSTORE_KEY_CONTENT или APPSTORE_KEY_PATH.'
      UI.important(status[:error])
      next status
    end

    app = Spaceship::ConnectAPI::App.find(app_identifier)

    if app.nil?
      status[:error] = "Приложение #{app_identifier} не найдено в App Store Connect"
      status[:state] = 'NOT_FOUND'
      UI.important(status[:error])
      next status
    end

    versions = app.get_app_store_versions(filter: { versionString: version_string, platform: 'IOS' })
    target_version = versions&.find { |v| v.version_string.to_s == version_string.to_s }

    if target_version.nil?
      status[:state] = 'NOT_FOUND'
      UI.message("Версия #{version_string} не найдена в App Store Connect")
      next status
    end

    state = target_version.app_store_state
    status[:state] = state
    status[:released] = state == 'READY_FOR_SALE' # READY_FOR_SALE считается опубликованной
    status[:app_store_version_id] = target_version.id
    status[:platform] = target_version.platform

    UI.success("Найдена версия #{version_string}, состояние: #{state}, released: #{status[:released]}")
  rescue StandardError => e
    status[:error] = e.message
    UI.important("⚠️  Ошибка при проверке релиза: #{e.message}")
  ensure
    # Определяем путь к корню проекта (где находится fastlane/)
    project_root = ENV['CI_PROJECT_DIR']
    
    unless project_root
      # Если CI_PROJECT_DIR не установлен, определяем корень проекта
      current_dir = Dir.pwd
      # Если мы в fastlane/, поднимаемся на уровень выше
      if File.basename(current_dir) == 'fastlane' || File.exist?(File.join(current_dir, 'Fastfile'))
        project_root = current_dir
      else
        # Ищем директорию с Fastfile (корень проекта)
        search_dir = current_dir
        while search_dir != '/' && !File.exist?(File.join(search_dir, 'fastlane', 'Fastfile'))
          search_dir = File.dirname(search_dir)
        end
        project_root = search_dir != '/' ? search_dir : current_dir
      end
    end
    
    release_status_path = File.join(project_root, 'release_status.json')
    File.write(release_status_path, JSON.pretty_generate(status))
    UI.message("Создан release_status.json: #{File.expand_path(release_status_path)}")
  end

  status
end

def prepare_api_key_for_release_check
  key_content = APPSTORE_KEY_CONTENT
  key_path = ENV['APPSTORE_KEY_PATH'] || ENV['APP_STORE_CONNECT_KEY_PATH']

  if APPSTORE_KEY_ID.to_s.empty? || APPSTORE_ISSUER_ID.to_s.empty?
    UI.important('⚠️  APPSTORE_KEY_ID или APPSTORE_ISSUER_ID не указаны')
    return nil
  end

  if key_content && !key_content.empty?
    content_is_base64 = !key_content.include?('BEGIN PRIVATE KEY')
    UI.message("Используем APPSTORE_KEY_CONTENT для авторизации (#{content_is_base64 ? 'base64' : 'PEM'})")

    return app_store_connect_api_key(key_id: APPSTORE_KEY_ID,
                                     issuer_id: APPSTORE_ISSUER_ID,
                                     key_content: key_content,
                                     in_house: false,
                                     is_key_content_base64: content_is_base64)
  end

  if key_path && !key_path.empty?
    expanded_path = File.expand_path(key_path)
    unless File.exist?(expanded_path)
      UI.important("⚠️  APPSTORE_KEY_PATH указан, но файл не найден: #{expanded_path}")
      return nil
    end

    UI.message("Используем ключ App Store Connect из файла: #{expanded_path}")

    return app_store_connect_api_key(key_id: APPSTORE_KEY_ID,
                                     issuer_id: APPSTORE_ISSUER_ID,
                                     keyfile: expanded_path,
                                     in_house: false)
  end

  nil
end

def increment_patch_version(version)
  # Разбиваем версию на части
  major, minor, patch = version.split('.').map(&:to_i)

  # Увеличиваем патч-версию
  patch += 1

  # Возвращаем новую версию в виде строки
  "#{major}.#{minor}.#{patch}"
end

