# Идентификатор приложения (Bundle Identifier)
# Пример: com.company.appname
APP_IDENTIFIER = ENV['APP_IDENTIFIER']

def infer_app_version_from_ci_branch
  branch_name = ENV['CI_COMMIT_BRANCH'] || ENV['CI_COMMIT_REF_NAME']
  match = branch_name.to_s.match(%r{\A(?:beta|release)/([0-9]+\.[0-9]+\.[0-9]+)\z})
  match && match[1]
end

def normalize_app_version(value)
  match = value.to_s.strip.match(%r{\A(?:beta|release)/([0-9]+\.[0-9]+\.[0-9]+)\z})
  match ? match[1] : value.to_s.strip
end

normalized_app_version = normalize_app_version(ENV['APP_VERSION'])
ENV['APP_VERSION'] = if normalized_app_version.empty?
                       infer_app_version_from_ci_branch
                     else
                       normalized_app_version
                     end

### Настройки проекта ###
# Файл проекта Xcode (если не указан, будет использоваться MAIN_TARGET.xcodeproj)
MAIN_PROJECT_FILE           = ENV['MAIN_PROJECT_FILE']
# Основной target для сборки
MAIN_TARGET                 = ENV['MAIN_TARGET']
# Схема Xcode для сборки. По умолчанию совпадает с target для обратной совместимости.
BUILD_SCHEME                = ENV['BUILD_SCHEME'] || ENV['SCHEME'] || MAIN_TARGET
# Конфигурация Xcode для сборки. Если не задана, fastlane использует настройку схемы.
BUILD_CONFIGURATION         = ENV['BUILD_CONFIGURATION'] || ENV['CONFIGURATION']

### Ключи App Store Connect API ###
# ID ключа API для App Store Connect
APPSTORE_KEY_ID             = ENV['APPSTORE_KEY_ID']
# ID издателя (Issuer ID) для App Store Connect
APPSTORE_ISSUER_ID          = ENV['APPSTORE_ISSUER_ID']
# Содержимое ключа API в формате Base64
APPSTORE_KEY_CONTENT        = ENV['APPSTORE_KEY_CONTENT']

# Fastlane по умолчанию ожидает FASTLANE_USER для логина в Developer Portal.
# Если задан только ACCOUNT_EMAIL, используем его как fallback.
FASTLANE_USER               = ENV['FASTLANE_USER'] || ENV['MATCH_USERNAME'] || ENV['ACCOUNT_EMAIL']
ENV['FASTLANE_USER']        = FASTLANE_USER if FASTLANE_USER.to_s.strip.length.positive?
ENV['MATCH_USERNAME']       = FASTLANE_USER if FASTLANE_USER.to_s.strip.length.positive?

# Match ожидает FASTLANE_TEAM_ID, а у нас в .env часто хранится TEAM_ID.
FASTLANE_TEAM_ID            = ENV['FASTLANE_TEAM_ID'] || ENV['TEAM_ID']
ENV['FASTLANE_TEAM_ID']     = FASTLANE_TEAM_ID if FASTLANE_TEAM_ID.to_s.strip.length.positive?

# Номер сборки (обычно берется из CI/CD переменной)
BUILD_NUMBER                = ENV['CI_PIPELINE_IID'] || ENV['BUILD_NUMBER']
# Ключ API для AppMetrica (для загрузки dSYM)
APPMETRICA_KEY              = ENV['APPMETRICA_KEY']
# Путь к helper скрипту для загрузки dSYM в AppMetrica
APPMETRICA_HELPER_PATH      = ENV['APPMETRICA_HELPER_PATH']

# Путь к директории для derived data (промежуточные файлы сборки)
DERIVED_PATH                = 'build'
# Путь к скрипту загрузки символов в Crashlytics (Firebase)
CRASHLYTICS_PATH            = './SourcePackages/checkouts/firebase-ios-sdk/Crashlytics/upload-symbols'

### Метаданные ###
# Путь к директории с метаданными приложения (описание, скриншоты и т.д.)
DATA_META_PATH              = './fastlane/metadata'
# Путь к директории со скриншотами приложения
DATA_SCREEN_PATH            = './fastlane/screenshots'

# Формирование имени файла для артефактов сборки
# Формат: {TARGET}_v{VERSION}_b{BUILD_NUMBER}
ARTIFACT_BASENAME           = ENV['ARTIFACT_BASENAME'] || BUILD_SCHEME
FILE_NAME                   = "#{ARTIFACT_BASENAME}_v#{ENV['APP_VERSION']}_b#{BUILD_NUMBER}"
# Корень проекта — каталог, СОДЕРЖАЩИЙ папку fastlane/. Именно относительно него
# fastlane-экшены (gym/build_app/copy_artifacts/sh) резолвят относительные пути.
# Плейн-руби (File.expand_path/File.exist?) использует Dir.pwd, который у fastlane
# равен самой папке fastlane/. Из-за этого относительный путь (например
# ARTIFACTS_PATH='fastlane/artifacts/') экшены кладут в <root>/fastlane/artifacts,
# а валидация ищет в <root>/fastlane/FASTLANE/artifacts (лишний сегмент) → «IPA не
# найден». Поэтому относительные пути из ENV привязываем к корню проекта.
def fastlane_tools_project_root
  # В CI корень проекта известен точно — берём его (GitLab CI_PROJECT_DIR /
  # GitHub GITHUB_WORKSPACE). Это надёжнее FastlaneCore::FastlaneFolder.path,
  # который в репо с вложенной папкой fastlane/fastlane/ (её плодит metrics.json)
  # возвращает путь на 1-2 уровня глубже и уводит относительные ARTIFACTS_PATH/
  # HELPER_PATH в несуществующий каталог (…/fastlane/fastlane/fastlane/…).
  ci_root = ENV['CI_PROJECT_DIR'] || ENV['GITHUB_WORKSPACE']
  return File.expand_path(ci_root) if ci_root && !ci_root.strip.empty?

  # Локально fastlane исполняет Fastfile с Dir.pwd = папкой fastlane/.
  # Корень проекта — её родитель (если basename == 'fastlane'), иначе сам Dir.pwd.
  pwd = Dir.pwd
  File.basename(pwd) == 'fastlane' ? File.expand_path('..', pwd) : pwd
end

# Разворачивает путь в абсолютный: '~' → HOME, абсолютный — как есть,
# относительный — относительно КОРНЯ ПРОЕКТА (а не Dir.pwd=папки fastlane/).
def expand_under_project_root(path)
  value = path.to_s.strip
  return value if value.empty?

  File.expand_path(value, fastlane_tools_project_root)
end

# Базовый путь для хранения артефактов сборки.
# По умолчанию — repo-local 'fastlane/artifacts/' (видно механизму CI-артефактов,
# HOME раннера не засоряется). Можно переопределить через ENV['ARTIFACTS_PATH']
# (в т.ч. на абсолютный путь или '~/...'). Относительный путь привязывается к
# корню проекта; результат всегда абсолютный и оканчивается на '/'.
# Прежний дефолт '~/.cache/apps/<TARGET>/' при необходимости задаётся явно через ENV.
ARTIFACTS_PATH = begin
  raw = ENV['ARTIFACTS_PATH'].to_s.strip
  raw = 'fastlane/artifacts/' if raw.empty?
  resolved = expand_under_project_root(raw) # делает путь абсолютным (~, rel→root)
  resolved.end_with?('/') ? resolved : "#{resolved}/"
end

# Имена файлов артефактов
IPA_FILE_NAME               = "#{FILE_NAME}.ipa"
DSYM_FILE_NAME              = "#{FILE_NAME}.app.dSYM.zip"

# Полные пути к директориям артефактов.
# IPA и dSYM храним ПЛОСКО прямо в ARTIFACTS_PATH (по умолчанию fastlane/artifacts/),
# БЕЗ подпапок ipa//dsyms/. Артефакты живут в рабочей директории проекта и
# передаются между job-ами CI через механизм artifacts (без выноса в ~/.cache).
# Плоский layout обязателен: shared-gitlab-ci основных проектов собирает артефакты
# плоским глобом (fastlane/artifacts/*.ipa, fastlane/artifacts/*.dSYM.zip) и
# подпапки не видит; стикеры собирают всю fastlane/artifacts/ рекурсивно — им плоско
# тоже подходит.
IPA_FOLDER_PATH             = ARTIFACTS_PATH.dup
DSYM_FOLDER_PATH            = ARTIFACTS_PATH.dup

# Полные пути к файлам артефактов
IPA_FILE_PATH               = IPA_FOLDER_PATH.to_s + IPA_FILE_NAME.to_s
DSYM_FILE_PATH              = DSYM_FOLDER_PATH.to_s + DSYM_FILE_NAME.to_s

# Путь к helper-бинарю AppMetrica для загрузки dSYM.
# По умолчанию 'fastlane/helper'. Переопределяется через ENV['HELPER_PATH'].
# Относительный путь привязывается к корню проекта (как и ARTIFACTS_PATH), поэтому
# File.exist? и sh видят один и тот же абсолютный путь. Если файла нет — ветка
# AppMetrica в upload_dsyms пропускается без ошибки.
HELPER_PATH                 = expand_under_project_root(
  ENV['HELPER_PATH'].to_s.strip.empty? ? 'fastlane/helper' : ENV['HELPER_PATH'].strip
)
# Флаг включения/выключения загрузки dSYM файлов
UPLOAD_DSYMS                = ENV['UPLOAD_DSYMS']
# Проверка, включена ли загрузка dSYM (по умолчанию включена, если не 'false')
UPLOAD_DSYMS_ENABLED        = UPLOAD_DSYMS.to_s.strip.downcase != 'false'
# Пароль для match (шифрование сертификатов и профилей)
MATCH_PASSWORD              = ENV['MATCH_PASSWORD']

# ==============================================================================
# ВСПОМОГАТЕЛЬНЫЕ ФУНКЦИИ
# ==============================================================================

# Проверка и установка значения по умолчанию для MAIN_PROJECT_FILE
# Если MAIN_PROJECT_FILE не установлен, используется значение {MAIN_TARGET}.xcodeproj
#
# @return [void]
def check_and_set_project_file
  if ENV['MAIN_PROJECT_FILE'].nil? || ENV['MAIN_PROJECT_FILE'].empty?
    ENV['MAIN_PROJECT_FILE'] = "#{ENV['MAIN_TARGET']}.xcodeproj"
    UI.message("MAIN_PROJECT_FILE не установлен, используется значение по умолчанию: #{ENV['MAIN_PROJECT_FILE']}")
  else
    UI.message("MAIN_PROJECT_FILE установлен, используется значение: #{ENV['MAIN_PROJECT_FILE']}")
  end
end

# ==============================================================================
# ИМПОРТ ВСПОМОГАТЕЛЬНЫХ ФУНКЦИЙ
# ==============================================================================
# Импорт helpers для retry логики, уведомлений и метрик
# Fastfile_helpers загружается через import_from_git dependencies
# Функции будут доступны после импорта всех зависимостей

# ==============================================================================
# ИМПОРТ МОДУЛЬНЫХ FASTFILE
# ==============================================================================
# Импорт Fastfile из удаленного git репозитория
# Используется path: 'fastlane/Fastfile_match' для избежания рекурсивного импорта
#
# Все зависимости автоматически импортируются:
#   - Fastfile_match: управление сертификатами и профилями (match)
#   - Fastfile_build: сборка приложений
#   - Fastfile_tests: запуск тестов
#   - Fastfile_dsyms: загрузка символов (dSYM)
#   - Fastfile_upload: загрузка в TestFlight
#   - Fastfile_appstore: работа с App Store (метаданные, публикация)
#   - Fastfile_create_app: создание нового приложения в App Store Connect
import_from_git(
  url: 'git@github.com:ESKARIA/fastlane-tools.git',
  # Ветка модулей. По умолчанию HEAD (main) — прежнее поведение. Переопределяется
  # через FASTLANE_TOOLS_BRANCH, чтобы проекты могли использовать feature-ветку
  # fastlane-tools целиком (внешний import_from_git той же ветки недостаточен:
  # вложенный импорт модулей иначе уйдёт в main).
  branch: ENV['FASTLANE_TOOLS_BRANCH'] || 'HEAD',
  path: 'fastlane/Fastfile_match', # Используется любой другой Fastfile кроме Fastfile для избежания рекурсии
  # version: [">= 1.0.0"], # Ограничение версии, если нужно
  dependencies: [
    'fastlane/Fastfile_build',        # Сборка приложений (iOS)
    'fastlane/Fastfile_macos',        # Сборка и публикация macOS приложений (platform :mac)
    'fastlane/Fastfile_macos_direct', # Прямая (Developer ID) дистрибуция macOS (platform :mac)
    'fastlane/Fastfile_tests',        # Запуск тестов
    'fastlane/Fastfile_dsyms',        # Загрузка символов
    'fastlane/Fastfile_upload',       # Загрузка в TestFlight
    'fastlane/Fastfile_appstore',     # Работа с App Store
    'fastlane/Fastfile_create_app',   # Создание приложения
    'fastlane/Fastfile_helpers'       # Вспомогательные функции
  ]
  # cache_path: "~/.cache/fastlane/imported/" # Путь для кэширования импортированных файлов
)

# ==============================================================================
# ХУКИ FASTLANE
# ==============================================================================

# Хук before_all выполняется перед запуском любого lane
# Используется для общей инициализации и настройки окружения
before_all do |lane, _options|
  # Начало сбора метрик для текущего lane (если helpers доступны)
  start_metrics(lane) if lane && respond_to?(:start_metrics)

  # Проверка и установка файла проекта по умолчанию
  check_and_set_project_file
  # Раскомментируйте для автоматического обновления fastlane перед запуском
  # update_fastlane

  # Keychain для подписи больше НЕ удаляем перед каждым запуском:
  # он создаётся/разблокируется идемпотентно в ensure_signing_keychain (Fastfile_build)
  # и держится постоянным (без авто-лока). Ручная очистка доступна как lane clear_keychain.

  # Дополнительные действия на CI/CD машинах
  if ENV['CI']
    UI.message('Запуск на удаленной CI машине')
    # Очистка derived data для чистых сборок
    clear_derived_data(derived_data_path: DERIVED_PATH)

    # Настройка API ключа App Store Connect для CI окружения
    app_store_connect_api_key(key_id: APPSTORE_KEY_ID,
                              issuer_id: APPSTORE_ISSUER_ID,
                              key_content: APPSTORE_KEY_CONTENT,
                              in_house: false,
                              is_key_content_base64: true)
  end
end

# Хук after_all выполняется после завершения любого lane
# Используется для очистки и финализации
after_all do |_lane|
  # Завершение сбора метрик
  finish_metrics(save_to_file: true) if respond_to?(:finish_metrics)

  # Keychain для подписи НЕ удаляем после завершения — он персистентный
  # (см. ensure_signing_keychain). Это устраняет повторное пересоздание/импорт
  # и GUI-запрос пароля из-за авто-блокировки.
end

# ==============================================================================
# ОБЩИЕ LANES
# ==============================================================================

# Очистка keychain и provisioning profiles
# Удаляет временные keychain и provisioning profiles, созданные fastlane
#
# @example
#   fastlane clear_keychain
desc 'Clear keychain and provisioning profiles'
lane :clear_keychain do
  # Установка системного keychain по умолчанию
  sh('security default-keychain -d user -s ~/Library/Keychains/login.keychain-db || true')
  # Удаление временного keychain fastlane, если существует
  sh('security delete-keychain ~/Library/Keychains/fastlane_tmp_keychain-db || true')
  # Удаление всех provisioning profiles (|| true для игнорирования ошибок)
  sh("rm -rf ~/Library/MobileDevice/Provisioning\ Profiles/*.mobileprovision || true")
end

# Обработчик ошибок - выполняется при возникновении ошибки в любом lane
# @param _lane [String] название lane, где произошла ошибка
# @param exception [Exception] объект исключения
# @param _options [Hash] опции lane
error do |lane, exception, _options|
  # Вывод сообщения об ошибке
  UI.error("❌ Ошибка в lane '#{lane}': #{exception.message}")

  # Завершение метрик с информацией об ошибке (если helpers доступны)
  if respond_to?(:finish_metrics) && defined?($current_metrics) && $current_metrics
    $current_metrics.add_metric('status', 'failed')
    $current_metrics.add_metric('error', exception.message)
    finish_metrics(save_to_file: true)
  end
end

