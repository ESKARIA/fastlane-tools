# Раскомментируйте строку ниже, если хотите автоматически обновлять fastlane
# update_fastlane

# Платформа по умолчанию для всех lanes
default_platform(:ios)

# ==============================================================================
# ПЕРЕМЕННЫЕ ОКРУЖЕНИЯ И КОНСТАНТЫ
