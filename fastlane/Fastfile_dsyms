# frozen_string_literal: true

require 'shellwords'

# Диагностика: документирует, что реально лежит в путях поиска dSYM на момент
# запуска lane. Нужна для отладки кейса «артефакты скачались, но *.dSYM.zip не
# найден» — печатает cwd, ожидаемое имя/путь dSYM и фактическое содержимое
# каждого search_path (только релевантные *.zip/*.dSYM*/*.ipa, с ограничением).
def dump_dsym_search_context(search_paths)
  require 'find'
  UI.header('🔎 Диагностика поиска dSYM')
  UI.message("cwd: #{Dir.pwd}")
  UI.message("ARTIFACTS_PATH: #{defined?(ARTIFACTS_PATH) ? ARTIFACTS_PATH : '—'}")
  UI.message("DSYM_FOLDER_PATH: #{defined?(DSYM_FOLDER_PATH) ? DSYM_FOLDER_PATH : '—'}")
  UI.message("Ожидаемое имя dSYM: #{defined?(DSYM_FILE_NAME) ? DSYM_FILE_NAME : '—'}")
  UI.message("Ожидаемый путь dSYM: #{defined?(DSYM_FILE_PATH) ? File.expand_path(DSYM_FILE_PATH) : '—'}")

  search_paths.each do |search_path|
    unless File.exist?(search_path)
      UI.important("  ✗ путь не существует: #{search_path}")
      next
    end

    matches = []
    total = 0
    Find.find(search_path) do |path|
      next if File.directory?(path)

      total += 1
      matches << path if path =~ /\.(dSYM(\.zip)?|zip|ipa)$/i
      Find.prune if matches.size >= 50
    end

    UI.message("  ✓ #{search_path} — всего файлов: #{total}, релевантных: #{matches.size}")
    matches.first(50).each { |m| UI.message("      • #{m}") }
  end
  UI.message('🔎 Конец диагностики поиска dSYM')
end

desc 'Upload symbols'
lane :upload_dsyms do |options|
  # Начало сбора метрик (если helpers доступны)
  start_metrics('upload_dsyms') if respond_to?(:start_metrics)

  unless UPLOAD_DSYMS_ENABLED
    UI.message('⚠️  Загрузка dSYM отключена (UPLOAD_DSYMS=false)')
    next # Используем next вместо return
  end

  UI.header('Загрузка символов (dSYM)')

  check_and_set_project_file

  # Отправка уведомления о начале загрузки dSYM (если включено)
  if ENV['TELEGRAM_ENABLED'] == 'true' && respond_to?(:notify_telegram_stage)
    notify_telegram_stage('Начало загрузки символов (dSYM)', {
                            'Версия' => ENV['APP_VERSION'] || 'не указана',
                            'Build' => BUILD_NUMBER.to_s,
                            'Target' => MAIN_TARGET.to_s
                          })
  end

  # AppMetrica включаем ТОЛЬКО когда реально есть и helper-бинарь, и ключ.
  # Раньше гейт был по HELPER_PATH ('./helper' — константа, всегда непустая),
  # из-за чего ветка AppMetrica запускалась всегда и падала с user_error
  # (helper не найден / APPMETRICA_KEY пуст) даже при firebase-only загрузке.
  helper_present = File.exist?(HELPER_PATH)
  metrica_key_present = !APPMETRICA_KEY.to_s.strip.empty?
  is_metrica = helper_present && metrica_key_present
  uploaded_to_metrica = false
  uploaded_to_firebase = false

  if is_metrica
    UI.message("Путь к helper: #{HELPER_PATH}")
    UI.message('Загрузка dSYM в AppMetrica...')
    sh("chmod +x #{Shellwords.escape(HELPER_PATH)}") if File.exist?(HELPER_PATH)
    unzip_and_upload(options)
    uploaded_to_metrica = true
    add_metric('uploaded_to_appmetrica', true) if respond_to?(:add_metric)
  else
    reason = if !helper_present
               "helper-бинарь не найден (#{HELPER_PATH})"
             else
               'APPMETRICA_KEY не задан'
             end
    UI.message("Пропуск загрузки в AppMetrica: #{reason}")
  end

  firebase = options[:firebase] ? true : false
  if firebase
    UI.message('Загрузка dSYM в Firebase Crashlytics...')
    require 'find'
    dsym_paths = []

    # Формируем список путей для поиска
    search_paths = []
    search_paths << '.'

    begin
      dsym_folder = File.expand_path(DSYM_FOLDER_PATH)
      search_paths << dsym_folder if dsym_folder && !dsym_folder.empty?
    rescue StandardError
      # DSYM_FOLDER_PATH не определен или невалиден
    end

    begin
      artifacts_folder = File.expand_path('fastlane/artifacts')
      search_paths << artifacts_folder if artifacts_folder && !artifacts_folder.empty?
    rescue StandardError
      # fastlane/artifacts не существует
    end

    search_paths.uniq!
    dump_dsym_search_context(search_paths)

    # Ищем файлы во всех путях
    search_paths.each do |search_path|
      next unless File.exist?(search_path)

      Find.find(search_path) do |path|
        dsym_paths << path if path.end_with?('.dSYM.zip')
      end
    end

    # Абсолютизируем + дедупим. upload_symbols_to_crashlytics резолвит
    # относительные пути от КОРНЯ проекта (stickers/), а cwd здесь — fastlane/,
    # поэтому './artifacts/...' не находится. Передаём абсолютные пути.
    dsym_paths = dsym_paths.map { |p| File.expand_path(p) }.uniq

    if dsym_paths.empty?
      UI.message('⚠️  Не найдено dSYM файлов для загрузки в Firebase')
    else
      UI.message("Найдено dSYM файлов: #{dsym_paths.count}")
      upload_symbols_to_crashlytics(dsym_paths: dsym_paths)
      UI.success('✅ dSYM успешно загружены в Firebase')
      uploaded_to_firebase = true
      add_metric('uploaded_to_firebase', true) if respond_to?(:add_metric)
      add_metric('dsym_files_count', dsym_paths.count) if respond_to?(:add_metric)
    end
  end

  # Отправка уведомления об успешной загрузке dSYM (если включено)
  if ENV['TELEGRAM_ENABLED'] == 'true' && respond_to?(:notify_telegram_success)
    upload_details = {
      'Версия' => ENV['APP_VERSION'] || 'не указана',
      'Build' => BUILD_NUMBER.to_s,
      'Target' => MAIN_TARGET.to_s
    }
    upload_details['AppMetrica'] = uploaded_to_metrica ? 'да' : 'нет'
    upload_details['Firebase'] = uploaded_to_firebase ? 'да' : 'нет'

    notify_telegram_success('Загрузка символов (dSYM) завершена', upload_details)
  end

  add_metric('status', 'success') if respond_to?(:add_metric)
end

lane :unzip_and_upload do |_options|
  require 'fileutils'
  require 'find'
  require 'shellwords'
  check_and_set_project_file

  dsym_paths = []
  UI.message('Поиск *.dSYM.zip файлов...')

  # Формируем список путей для поиска
  search_paths = []
  search_paths << '.'

  begin
    dsym_folder = File.expand_path(DSYM_FOLDER_PATH)
    search_paths << dsym_folder if dsym_folder && !dsym_folder.empty?
  rescue StandardError
    # DSYM_FOLDER_PATH не определен или невалиден
  end

  begin
    artifacts_folder = File.expand_path('fastlane/artifacts')
    search_paths << artifacts_folder if artifacts_folder && !artifacts_folder.empty?
  rescue StandardError
    # fastlane/artifacts не существует
  end

  search_paths.uniq!
  dump_dsym_search_context(search_paths)

  # Ищем файлы во всех путях
  search_paths.each do |search_path|
    next unless File.exist?(search_path)

    UI.message("Ищем в: #{search_path}")
    Find.find(search_path) do |path|
      dsym_paths << path if path.end_with?('.dSYM.zip')
    end
  end

  # Дедуп по АБСОЛЮТНОМУ пути: один и тот же zip находится и по '.', и по
  # absolute DSYM_FOLDER_PATH — без этого он распаковывается/заливается дважды.
  dsym_paths = dsym_paths.uniq { |p| File.expand_path(p) }

  if dsym_paths.empty?
    UI.message('⚠️  Не найдено dSYM.zip файлов')
    next # Используем next вместо return
  end

  UI.message("Найдено dSYM.zip файлов: #{dsym_paths.count}")

  dsym_paths.each do |zip_file|
    if File.exist?(zip_file)
      UI.message("Обработка: #{zip_file}")
      UI.message('Распаковка архива...')
      sh("unzip -o -q #{zip_file.shellescape}") # -q для тихого режима; имя с пробелами → shellescape
      UI.message('Распаковка завершена')

      if File.exist?(HELPER_PATH)
        UI.message('Загрузка dSYM через helper скрипт...')
        sh("#{HELPER_PATH.shellescape} -k #{APPMETRICA_KEY.to_s.shellescape} -v")
        UI.success("✅ dSYM загружен: #{zip_file}")
      else
        UI.user_error!("Helper скрипт не найден: #{HELPER_PATH}")
      end
    else
      UI.message("⚠️  Файл не найден: #{zip_file}")
    end
  end
end
