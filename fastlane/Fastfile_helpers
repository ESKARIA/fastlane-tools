# Класс для сбора метрик выполнения lanes
class FastlaneMetrics
  attr_accessor :start_time, :end_time, :lane_name, :metrics

  def initialize(lane_name)
    @lane_name = lane_name
    @start_time = Time.now
    @end_time = nil
    @metrics = {}

    # Автоматическое добавление базовой контекстной информации
    add_context_metrics
  end

  # Добавляет базовую контекстную информацию о проекте
  def add_context_metrics
    # Информация о проекте
    project_name = ENV['CI_PROJECT_NAME'] || ENV['GITHUB_REPOSITORY'] || ENV['CI_PROJECT_PATH'] || 'не указан'
    @metrics[:project] = project_name

    # Target приложения
    if defined?(MAIN_TARGET) && MAIN_TARGET
      @metrics[:target] = MAIN_TARGET.to_s
    elsif ENV['MAIN_TARGET']
      @metrics[:target] = ENV['MAIN_TARGET']
    end

    # Версия приложения
    @metrics[:version] = ENV['APP_VERSION'] if ENV['APP_VERSION'] && !ENV['APP_VERSION'].empty?

    # Build number
    if defined?(BUILD_NUMBER) && BUILD_NUMBER
      @metrics[:build_number] = BUILD_NUMBER.to_s
    elsif ENV['CI_PIPELINE_IID']
      @metrics[:build_number] = ENV['CI_PIPELINE_IID']
    elsif ENV['BUILD_NUMBER']
      @metrics[:build_number] = ENV['BUILD_NUMBER']
    end

    # CI/CD система
    @metrics[:ci_system] = if ENV['CI']
                             if ENV['CI_PIPELINE_URL'] || ENV['CI_JOB_URL']
                               'GitLab CI'
                             elsif ENV['GITHUB_SERVER_URL']
                               'GitHub Actions'
                             elsif ENV['BUILD_URL'] || ENV['JOB_URL']
                               'Jenkins'
                             else
                               'CI/CD'
                             end
                           else
                             'Local'
                           end

    # Pipeline URL (если доступен)
    # Вызываем глобальную функцию get_pipeline_url
    begin
      # Функция определена в том же файле, поэтому доступна в контексте
      pipeline_url = get_pipeline_url
      @metrics[:pipeline_url] = pipeline_url if pipeline_url
    rescue StandardError
      # Если функция недоступна, просто пропускаем
    end

    # Pipeline ID
    if ENV['CI_PIPELINE_IID']
      @metrics[:pipeline_id] = ENV['CI_PIPELINE_IID']
    elsif ENV['GITHUB_RUN_ID']
      @metrics[:pipeline_id] = ENV['GITHUB_RUN_ID']
    elsif ENV['BUILD_NUMBER']
      @metrics[:pipeline_id] = ENV['BUILD_NUMBER']
    end
  end

  # Добавляет метрику
  def add_metric(key, value)
    @metrics[key] = value
  end

  # Завершает сбор метрик
  def finish
    @end_time = Time.now
    @metrics[:duration_seconds] = (@end_time - @start_time).round(2)
    @metrics[:duration_formatted] = format_duration(@metrics[:duration_seconds])
  end

  # Форматирует длительность в читаемый вид
  def format_duration(seconds)
    if seconds < 60
      "#{seconds.round(1)} сек"
    elsif seconds < 3600
      minutes = (seconds / 60).floor
      secs = (seconds % 60).round
      "#{minutes} мин #{secs} сек"
    else
      hours = (seconds / 3600).floor
      minutes = ((seconds % 3600) / 60).floor
      "#{hours} ч #{minutes} мин"
    end
  end

  # Выводит метрики в консоль
  def print
    UI.header("📊 Метрики выполнения: #{@lane_name}")

    # Группировка метрик по категориям для лучшей читаемости
    context_metrics = {}
    custom_metrics = {}
    time_metrics = {}

    @metrics.each do |key, value|
      case key.to_s
      when /^(project|target|version|build_number|ci_system|pipeline|app_identifier)$/
        context_metrics[key] = value
      when /^(duration|time)/
        time_metrics[key] = value
      else
        custom_metrics[key] = value
      end
    end

    # Вывод контекстной информации
    unless context_metrics.empty?
      UI.message('📋 Контекст:')
      context_metrics.each do |key, value|
        UI.message("  #{format_metric_key(key)}: #{value}")
      end
    end

    # Вывод временных метрик
    unless time_metrics.empty?
      UI.message('⏱️  Время выполнения:')
      time_metrics.each do |key, value|
        UI.message("  #{format_metric_key(key)}: #{value}")
      end
    end

    # Вывод пользовательских метрик
    return if custom_metrics.empty?

    UI.message('📈 Дополнительные метрики:')
    custom_metrics.each do |key, value|
      UI.message("  #{format_metric_key(key)}: #{value}")
    end
  end

  # Форматирует ключ метрики для вывода
  def format_metric_key(key)
    key.to_s.gsub('_', ' ').split.map(&:capitalize).join(' ')
  end

  # Сохраняет метрики в файл
  #
  # По умолчанию путь привязан к каталогу самого Fastfile_helpers (__dir__),
  # а не к Dir.pwd (который у fastlane равен папке fastlane/) — иначе
  # относительный 'fastlane/metrics.json' создаёт вложенную fastlane/fastlane/.
  def save_to_file(file_path = File.expand_path('metrics.json', __dir__))
    metrics_data = {
      lane: @lane_name,
      timestamp: @start_time.iso8601,
      end_time: @end_time&.iso8601,
      # Контекстная информация для удобного поиска
      context: {
        project: @metrics[:project],
        target: @metrics[:target],
        version: @metrics[:version],
        build_number: @metrics[:build_number],
        ci_system: @metrics[:ci_system],
        pipeline_id: @metrics[:pipeline_id]
      },
      metrics: @metrics
    }

    # Создание директории, если она не существует
    file_dir = File.dirname(file_path)
    FileUtils.mkdir_p(file_dir) unless File.directory?(file_dir)

    # Чтение существующих метрик
    existing_metrics = []
    if File.exist?(file_path)
      begin
        existing_metrics = JSON.parse(File.read(file_path))
      rescue StandardError
        existing_metrics = []
      end
    end

    # Добавление новых метрик
    existing_metrics << metrics_data

    # Сохранение (сохраняем только последние 100 записей)
    existing_metrics = existing_metrics.last(100)

    File.write(file_path, JSON.pretty_generate(existing_metrics))
    UI.message("📊 Метрики сохранены в #{file_path}")
  end
end

# Глобальная переменная для хранения метрик текущего lane
$current_metrics = nil

# Начинает сбор метрик для lane
#
# @param lane_name [String] название lane
# @return [FastlaneMetrics] объект метрик
def start_metrics(lane_name)
  $current_metrics = FastlaneMetrics.new(lane_name)
  $current_metrics
end

# Завершает сбор метрик и выводит их
#
# @param save_to_file [Boolean] сохранять ли метрики в файл
def finish_metrics(save_to_file: true)
  return unless $current_metrics

  $current_metrics.finish
  $current_metrics.print

  $current_metrics.save_to_file if save_to_file

  $current_metrics
end

# Добавляет метрику к текущему объекту метрик
#
# @param key [String] название метрики
# @param value [Object] значение метрики
def add_metric(key, value)
  $current_metrics&.add_metric(key, value)
end

# ==============================================================================
# РАБОТА С APP_IDENTIFIER
# ==============================================================================

# Получает все bundle identifiers из переменной окружения APP_IDENTIFIER
#
# Поддерживает несколько идентификаторов, разделенных запятой.
# Пример: "com.app.main,com.app.widget,com.app.watchkit"
#
# @return [Array<String>] массив bundle identifiers (без пустых строк)
#
# @example
#   identifiers = get_all_app_identifiers
#   # => ["com.app.main", "com.app.widget"]
def get_all_app_identifiers
  APP_IDENTIFIER.to_s.split(',').map(&:strip).reject(&:empty?)
end

# Получает первый (основной) bundle identifier
#
# Используется для операций, которые требуют только один identifier
# (например, загрузка в TestFlight, проверка версий).
#
# @return [String] первый bundle identifier
# @raise [FastlaneCore::Interface::FastlaneError] если APP_IDENTIFIER не установлен
#
# @example
#   identifier = get_primary_app_identifier
#   # => "com.app.main"
def get_primary_app_identifier
  identifiers = get_all_app_identifiers
  UI.user_error!('❌ APP_IDENTIFIER не установлен или пуст') if identifiers.empty?
  identifiers.first
end

# ==============================================================================
# РЕГИСТРАЦИЯ MAC-УСТРОЙСТВА (чистая логика, вызывается из Fastfile_macos)
# ==============================================================================

# Извлекает Provisioning UDID из вывода `system_profiler SPHardwareDataType`.
#
# На Apple Silicon именно "Provisioning UDID" (не Hardware UUID) нужен для
# регистрации устройства в App Store Connect под macOS development-профиль.
#
# @param system_profiler_output [String] сырой вывод `system_profiler SPHardwareDataType`
# @return [String, nil] UDID или nil, если не найден в выводе
#
# @example
#   parse_provisioning_udid("Provisioning UDID: 00008103-000A2D8E3C28001E\n")
#   # => "00008103-000A2D8E3C28001E"
def parse_provisioning_udid(system_profiler_output)
  udid = system_profiler_output.to_s[/Provisioning UDID:\s*([0-9A-Fa-f-]+)/, 1]
  udid&.strip
end

# Возвращает отображаемое имя Mac-устройства для register_devices.
#
# @param computer_name [String] значение `scutil --get ComputerName` (может быть пустым)
# @param udid [String] Provisioning UDID устройства
# @return [String] computer_name (без пробелов по краям), если непустой,
#   иначе фоллбэк вида "Mac <последние 6 символов udid>"
#
# @example
#   mac_device_display_name("Emil's MacBook Pro", "00008103-000A2D8E3C28001E")
#   # => "Emil's MacBook Pro"
#   mac_device_display_name("", "00008103-000A2D8E3C28001E")
#   # => "Mac 8001E"
def mac_device_display_name(computer_name, udid)
  name = computer_name.to_s.strip
  return name unless name.empty?

  "Mac #{udid.to_s[-6..]}"
end

# ==============================================================================
# РАБОТА С ПУТЯМИ И ФАЙЛАМИ
# ==============================================================================

# Нормализует путь к IPA файлу
#
# Добавляет префикс 'fastlane/' если путь не начинается с него.
# Используется для унификации путей к IPA файлам.
#
# @param ipa_path [String] путь к IPA файлу
# @return [String] нормализованный путь
#
# @example
#   normalize_ipa_path("artifacts/app.ipa")
#   # => "fastlane/artifacts/app.ipa"
#
#   normalize_ipa_path("fastlane/artifacts/app.ipa")
#   # => "fastlane/artifacts/app.ipa"
def normalize_ipa_path(ipa_path)
  ipa_path.start_with?('fastlane/') ? ipa_path : "fastlane/#{ipa_path}"
end

# Находит файлы по паттерну в указанных директориях
#
# Рекурсивно ищет файлы, соответствующие паттерну, в указанных директориях.
# Используется для поиска IPA, dSYM и других артефактов.
#
# @param pattern [String] паттерн для поиска (например, "*.ipa", "*.dSYM.zip")
# @param search_paths [Array<String>] массив путей для поиска
# @return [Array<String>] массив найденных файлов (уникальные пути)
#
# @example
#   ipa_files = find_artifact_files(pattern: "*.ipa", search_paths: [".", "artifacts"])
#   # => ["./app.ipa", "artifacts/app.ipa"]
def find_artifact_files(pattern:, search_paths: [])
  require 'find'
  found_files = []

  search_paths.each do |search_path|
    expanded_path = File.expand_path(search_path)
    next unless File.directory?(expanded_path)

    Find.find(expanded_path) do |path|
      found_files << path if File.file?(path) && File.fnmatch?(pattern, File.basename(path))
    end
  end

  found_files.uniq
end

# ==============================================================================
# МУЛЬТИПЛАТФОРМЕННЫЕ СХЕМЫ (Xcode "Multiplatform App" — один target/scheme,
# несколько платформ одновременно, например iOS+macOS)
# ==============================================================================
# Используется в Fastfile_build (lane :build, iOS) и Fastfile_macos (lane
# :build) — подробности и обоснование см. комментарий у первого места
# использования в Fastfile_build. Вынесена сюда (а не определена локально в
# каждом из модулей) как чистая Ruby-логика без Fastlane DSL, чтобы её можно
# было протестировать напрямую через spec_helper (по аналогии с
# parse_provisioning_udid/mac_device_display_name).
#
# @param options [Hash] опции лейна (options[:multiplatform])
# @return [Boolean] true — включён мультиплатформенный режим версионирования/sdk
def multiplatform_scheme?(options)
  options[:multiplatform] == true || ENV['MULTIPLATFORM_SCHEME'].to_s == 'true'
end
