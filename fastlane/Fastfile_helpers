# Отправляет уведомление в Telegram
#
# @param message [String] текст сообщения
# @param bot_token [String] токен Telegram бота (из переменной TELEGRAM_BOT_TOKEN)
# @param chat_id [String] ID чата для отправки (из переменной TELEGRAM_CHAT_ID)
# @param parse_mode [String] режим парсинга ('HTML' или 'Markdown')
# @param disable_notification [Boolean] отправлять ли без звука
# @return [Boolean] true, если сообщение отправлено успешно
#
# @example
#   send_telegram_notification("✅ Сборка завершена успешно")
def send_telegram_notification(message, bot_token: nil, chat_id: nil, parse_mode: 'HTML', disable_notification: false)
  # Получение параметров из переменных окружения
  bot_token ||= ENV['TELEGRAM_BOT_TOKEN']
  chat_id ||= ENV['TELEGRAM_CHAT_ID']

  # Проверка наличия обязательных параметров
  if bot_token.nil? || bot_token.empty?
    UI.important('⚠️  TELEGRAM_BOT_TOKEN не установлен, уведомление не отправлено')
    return false
  end

  if chat_id.nil? || chat_id.empty?
    UI.important('⚠️  TELEGRAM_CHAT_ID не установлен, уведомление не отправлено')
    return false
  end

  # Формирование URL для отправки сообщения
  uri = URI("https://api.telegram.org/bot#{bot_token}/sendMessage")

  # Параметры запроса
  params = {
    chat_id: chat_id,
    text: message,
    parse_mode: parse_mode,
    disable_notification: disable_notification
  }

  begin
    # Отправка запроса
    http = Net::HTTP.new(uri.host, uri.port)
    http.use_ssl = true
    http.read_timeout = 10
    http.open_timeout = 10

    request = Net::HTTP::Post.new(uri.path)
    request.set_form_data(params)

    response = http.request(request)

    if response.code == '200'
      UI.success('✅ Уведомление отправлено в Telegram')
      true
    else
      UI.important("⚠️  Не удалось отправить уведомление в Telegram: #{response.code}")
      UI.message("Ответ: #{response.body}")
      false
    end
  rescue StandardError => e
    UI.important("⚠️  Ошибка при отправке уведомления в Telegram: #{e.message}")
    false
  end
end

# Получает ссылку на pipeline/job из переменных окружения CI/CD
#
# Поддерживает:
# - GitLab CI: CI_PIPELINE_URL, CI_JOB_URL
# - GitHub Actions: GITHUB_SERVER_URL, GITHUB_REPOSITORY, GITHUB_RUN_ID
# - Jenkins: BUILD_URL, JOB_URL
#
# @return [String, nil] ссылка на pipeline или nil, если не найдена
def get_pipeline_url
  # GitLab CI
  if ENV['CI_PIPELINE_URL']
    return ENV['CI_PIPELINE_URL']
  elsif ENV['CI_JOB_URL']
    return ENV['CI_JOB_URL']
  elsif ENV['CI_PROJECT_URL'] && ENV['CI_PIPELINE_IID']
    return "#{ENV['CI_PROJECT_URL']}/-/pipelines/#{ENV['CI_PIPELINE_IID']}"
  end

  # GitHub Actions
  if ENV['GITHUB_SERVER_URL'] && ENV['GITHUB_REPOSITORY'] && ENV['GITHUB_RUN_ID']
    return "#{ENV['GITHUB_SERVER_URL']}/#{ENV['GITHUB_REPOSITORY']}/actions/runs/#{ENV['GITHUB_RUN_ID']}"
  end

  # Jenkins
  if ENV['BUILD_URL']
    return ENV['BUILD_URL']
  elsif ENV['JOB_URL']
    return ENV['JOB_URL']
  end

  nil
end

# Форматирует сообщение для Telegram с эмодзи и HTML тегами
#
# @param title [String] заголовок сообщения
# @param details [Hash] детали сообщения
# @param include_pipeline_link [Boolean] включать ли ссылку на pipeline (по умолчанию true)
# @return [String] отформатированное сообщение
#
# @example
#   message = format_telegram_message("✅ Сборка завершена", {
#     "Версия" => "1.2.3",
#     "Build" => "456"
#   })
def format_telegram_message(title, details = {}, include_pipeline_link: true, pipeline_url: nil)
  safe_details = details || {}

  message = "<b>#{title}</b>\n"
  message += "━━━━━━━━━━━━━━━━━━━━\n"

  # Короткая сводка: target + версия + build
  version_entry = safe_details.detect { |key, _| key.to_s.downcase.match?(/версия|version/) }
  build_entry = safe_details.detect { |key, _| key.to_s.downcase.match?(/build|сборка/) }
  target_entry = safe_details.detect { |key, _| key.to_s.downcase.match?(/target|таргет|scheme|схема/) }

  summary_parts = []
  summary_parts << "🎯 #{target_entry[1]}" if target_entry
  summary_parts << "📱 v#{version_entry[1]}" if version_entry
  summary_parts << "🔢 b#{build_entry[1]}" if build_entry
  message += "\n#{summary_parts.join(' • ')}\n" unless summary_parts.empty?
  message += "\n" if summary_parts.empty?

  sections = {
    main: [],
    artifacts: [],
    timing: [],
    people: [],
    errors: [],
    misc: []
  }

  safe_details.each do |key, value|
    normalized_key = key.to_s.downcase
    formatted_value = if value.is_a?(Float)
                        value.round(2).to_s
                      elsif value.is_a?(Array)
                        value.join(', ')
                      else
                        value.to_s
                      end

    emoji = case normalized_key
            when /версия|version/
              '📱'
            when /build|сборка/
              '🔢'
            when /размер|size/
              '📦'
            when /ipa|файл|file|path|путь|artifact|архив/
              '📄'
            when /группы|groups|tester|тест/
              '👥'
            when /время|time|duration|speed/
              '⏱️'
            when /lane|scheme|target/
              '🛣️'
            when /ошибка|error|fail|exception/
              '❌'
            else
              '•'
            end

    bucket = case normalized_key
             when /версия|version|build|сборка|target|bundle|scheme|lane|project|app/
               :main
             when /ipa|d?sym|artifact|file|файл|путь|path|pkg|apk|size|размер|archive/
               :artifacts
             when /время|time|duration|speed/
               :timing
             when /group|tester|user|owner|team|команда|группа/
               :people
             when /ошибка|error|fail|exception|reason/
               :errors
             else
               :misc
             end

    sections[bucket] << "#{emoji} <b>#{key}:</b> <code>#{formatted_value}</code>"
  end

  section_titles = {
    main: '🧭 Контекст',
    artifacts: '📦 Артефакты',
    timing: '⏱️ Время',
    people: '👥 Пользователи',
    errors: '❌ Ошибки',
    misc: '➕ Дополнительно'
  }

  sections.each do |bucket, lines|
    next if lines.empty?

    message += "\n<b>#{section_titles[bucket]}</b>\n"
    lines.each { |line| message += "#{line}\n" }
  end

  # Добавление ссылки на pipeline
  if include_pipeline_link
    pipeline_url ||= get_pipeline_url
    message += "\n🔗 <a href=\"#{pipeline_url}\">Открыть Pipeline</a>\n" if pipeline_url
  end

  message
end

# Отправляет уведомление о начале процесса в Telegram
#
# @param title [String] заголовок уведомления
# @param details [Hash] детали (версия, build и т.д.)
# @param include_pipeline_link [Boolean] включать ли ссылку на pipeline
def notify_telegram_start(title, details = {}, include_pipeline_link: true)
  # Добавление информации о lane, если доступна
  enhanced_details = details.dup
  if defined?($current_metrics) && $current_metrics && $current_metrics.lane_name
    enhanced_details['Lane'] = $current_metrics.lane_name
  end

  message = format_telegram_message("🚀 #{title}", enhanced_details, include_pipeline_link: include_pipeline_link)
  send_telegram_notification(message)
end

# Редактирует существующее сообщение в Telegram
#
# @param message_id [Integer] ID сообщения для редактирования
# @param message [String] новый текст сообщения
# @param bot_token [String] токен Telegram бота
# @param chat_id [String] ID чата
# @param parse_mode [String] режим парсинга ('HTML' или 'Markdown')
# @return [Boolean] true, если сообщение обновлено успешно
def edit_telegram_message(message_id, message, bot_token: nil, chat_id: nil, parse_mode: 'HTML')
  bot_token ||= ENV['TELEGRAM_BOT_TOKEN']
  chat_id ||= ENV['TELEGRAM_CHAT_ID']

  if bot_token.nil? || bot_token.empty? || chat_id.nil? || chat_id.empty?
    UI.important('⚠️  Не удалось обновить сообщение: отсутствуют bot_token или chat_id')
    return false
  end

  uri = URI("https://api.telegram.org/bot#{bot_token}/editMessageText")

  params = {
    chat_id: chat_id,
    message_id: message_id,
    text: message,
    parse_mode: parse_mode
  }

  begin
    http = Net::HTTP.new(uri.host, uri.port)
    http.use_ssl = true
    http.read_timeout = 10
    http.open_timeout = 10

    request = Net::HTTP::Post.new(uri.path)
    request.set_form_data(params)

    response = http.request(request)

    if response.code == '200'
      UI.success("✅ Сообщение успешно обновлено (ID: #{message_id})")
      true
    else
      response_body = response.body
      UI.important("⚠️  Не удалось обновить сообщение в Telegram: #{response.code}")
      UI.message("Ответ: #{response_body}")

      # Если сообщение не найдено (возможно, было удалено), возвращаем false
      # чтобы создать новое сообщение
      if response_body.to_s.include?('message not found') || response_body.to_s.include?('message to edit not found')
        UI.important('⚠️  Сообщение не найдено (возможно, было удалено). Будет создано новое.')
      end

      false
    end
  rescue StandardError => e
    UI.important("⚠️  Ошибка при обновлении сообщения в Telegram: #{e.message}")
    false
  end
end

# Путь к файлу для сохранения message_id между job'ами в CI/CD
PROGRESS_MESSAGE_ID_FILE = 'fastlane/.telegram_progress_message_id'
# Путь к файлу для сохранения деталей всех этапов
PROGRESS_STAGES_DETAILS_FILE = 'fastlane/.telegram_stages_details.json'
# Путь к файлу для сохранения списка выполненных этапов
PROGRESS_COMPLETED_STAGES_FILE = 'fastlane/.telegram_completed_stages.txt'

# Получает или создает ID сообщения для отслеживания прогресса
#
# Пытается получить из переменной окружения (для одного job) или из файла (для разных job'ов в CI/CD)
#
# @return [Integer, nil] ID сообщения или nil
def get_progress_message_id
  # Сначала пытаемся получить из переменной окружения (для одного job)
  message_id = ENV['TELEGRAM_PROGRESS_MESSAGE_ID']
  if message_id && !message_id.empty?
    UI.message("📝 Найден message_id в переменной окружения: #{message_id}")
    return message_id.to_i
  end

  # Затем пытаемся получить из файла (для разных job'ов в CI/CD)
  file_path = File.expand_path(PROGRESS_MESSAGE_ID_FILE)
  if File.exist?(file_path)
    begin
      message_id = File.read(file_path).strip
      if message_id && !message_id.empty?
        UI.message("📝 Найден message_id в файле #{file_path}: #{message_id}")
        return message_id.to_i
      else
        UI.message("⚠️  Файл #{file_path} существует, но пуст")
      end
    rescue StandardError => e
      UI.important("⚠️  Не удалось прочитать message_id из файла #{file_path}: #{e.message}")
    end
  else
    UI.message("ℹ️  Файл #{file_path} не найден - будет создано новое сообщение")
    # Проверяем также относительный путь на случай, если мы в другой директории
    if File.exist?(PROGRESS_MESSAGE_ID_FILE)
      begin
        message_id = File.read(PROGRESS_MESSAGE_ID_FILE).strip
        if message_id && !message_id.empty?
          UI.message("📝 Найден message_id в относительном пути #{PROGRESS_MESSAGE_ID_FILE}: #{message_id}")
          return message_id.to_i
        end
      rescue StandardError => e
        UI.important("⚠️  Не удалось прочитать message_id из относительного пути: #{e.message}")
      end
    end
  end

  nil
end

# Сохраняет ID сообщения для отслеживания прогресса
#
# Сохраняет в переменную окружения и в файл для передачи между job'ами в CI/CD
#
# @param message_id [Integer] ID сообщения
def save_progress_message_id(message_id)
  # Сохраняем в переменную окружения (для текущего job)
  ENV['TELEGRAM_PROGRESS_MESSAGE_ID'] = message_id.to_s
  UI.message("💾 Сохранен message_id в переменную окружения: #{message_id}")

  # Сохраняем в файл (для передачи между job'ами в CI/CD)
  begin
    file_path = File.expand_path(PROGRESS_MESSAGE_ID_FILE)
    FileUtils.mkdir_p(File.dirname(file_path))
    File.write(file_path, message_id.to_s)
    UI.message("💾 Сохранен message_id в файл #{file_path}: #{message_id}")

    # Также сохраняем в относительный путь для совместимости
    FileUtils.mkdir_p(File.dirname(PROGRESS_MESSAGE_ID_FILE))
    File.write(PROGRESS_MESSAGE_ID_FILE, message_id.to_s)
    UI.message("💾 Сохранен message_id в относительный путь #{PROGRESS_MESSAGE_ID_FILE}: #{message_id}")
  rescue StandardError => e
    UI.important("⚠️  Не удалось сохранить message_id в файл: #{e.message}")
  end
end

# Определяет этапы pipeline из GitLab CI переменных или контекста
#
# @return [Array<String>] массив названий этапов
def get_pipeline_stages
  # Определяем этапы из GitLab CI переменных
  if ENV['CI_PIPELINE_SOURCE'] || ENV['CI_PROJECT_URL']
    # Стандартные этапы для iOS сборки
    stages = ['Сборка проекта', 'Загрузка dSYM', 'Загрузка в TestFlight']

    # Можно добавить дополнительные этапы на основе переменных CI
    # Например, если есть этап проверки релиза
    if ENV['CI_JOB_STAGE'] == 'check_released' || ENV['CI_JOB_STAGE'] == 'set_tag'
      stages << 'Проверка релиза'
    end

    return stages
  end

  # По умолчанию возвращаем стандартные этапы
  ['Сборка проекта', 'Загрузка dSYM', 'Загрузка в TestFlight']
end

# Определяет текущий этап на основе названия lane
#
# @param lane_name [String] название lane
# @return [String] название этапа
def get_current_stage_name(lane_name)
  stage_mapping = {
    'build' => 'Сборка проекта',
    'upload_dsyms' => 'Загрузка dSYM',
    'upload_testflight' => 'Загрузка в TestFlight',
    'upload_external_testflight' => 'Загрузка в TestFlight'
  }

  stage_mapping[lane_name.to_s] || lane_name.to_s
end

# Форматирует прогресс-бар этапов
#
# @param stages [Array<String>] все этапы
# @param completed_stages [Array<String>] выполненные этапы
# @param current_stage [String, nil] текущий выполняемый этап
# @return [String] отформатированный прогресс-бар
def format_stages_progress(stages, completed_stages = [], current_stage = nil)
  progress_lines = []

  stages.each do |stage|
    if completed_stages.include?(stage)
      progress_lines << "✅ #{stage}"
    elsif current_stage == stage
      progress_lines << "🔄 #{stage} (в процессе...)"
    else
      progress_lines << "⏳ #{stage}"
    end
  end

  progress_lines.join("\n")
end

# Создает или обновляет прогресс-сообщение в Telegram
#
# В режиме прогресс-сообщения ВСЕГДА обновляет одно и то же сообщение.
# Создает новое сообщение только если это первый вызов (message_id не найден).
#
# @param stage_name [String] название текущего этапа
# @param status [String] статус ('start', 'success', 'error')
# @param details [Hash] детали этапа
# @param error_message [String, nil] сообщение об ошибке (если есть)
# @return [Integer, nil] ID сообщения
def update_telegram_progress(stage_name, status: 'start', details: {}, error_message: nil)
  return nil unless ENV['TELEGRAM_ENABLED'] == 'true'

  bot_token = ENV['TELEGRAM_BOT_TOKEN']
  chat_id = ENV['TELEGRAM_CHAT_ID']

  return nil if bot_token.nil? || bot_token.empty? || chat_id.nil? || chat_id.empty?

  # ВАЖНО: Сначала пытаемся получить message_id ДО формирования сообщения
  # Это гарантирует, что мы обновим существующее сообщение, а не создадим новое
  message_id = get_progress_message_id

  if message_id
    UI.message("✅ Найден существующий message_id: #{message_id} - будет обновлено существующее сообщение")
  else
    UI.message('ℹ️  message_id не найден - будет создано новое сообщение (только для первого этапа)')
  end

  # Получаем все этапы
  all_stages = get_pipeline_stages

  # Определяем выполненные этапы на основе сохраненного состояния
  completed_stages = []

  # Сначала пытаемся получить из переменной окружения (для одного job)
  if ENV['TELEGRAM_COMPLETED_STAGES']
    completed_stages = ENV['TELEGRAM_COMPLETED_STAGES'].split(',').map(&:strip)
  end

  # Затем пытаемся получить из файла (для разных job'ов в CI/CD)
  if File.exist?(PROGRESS_COMPLETED_STAGES_FILE)
    begin
      file_stages = File.read(PROGRESS_COMPLETED_STAGES_FILE).strip.split(',').map(&:strip).reject(&:empty?)
      completed_stages = (completed_stages + file_stages).uniq
    rescue StandardError => e
      UI.important("⚠️  Не удалось прочитать выполненные этапы из файла: #{e.message}")
    end
  end

  # Если этап успешно завершен, добавляем его в список выполненных
  if status == 'success'
    completed_stages << stage_name unless completed_stages.include?(stage_name)
    ENV['TELEGRAM_COMPLETED_STAGES'] = completed_stages.join(',')

    # Сохраняем в файл
    begin
      FileUtils.mkdir_p(File.dirname(PROGRESS_COMPLETED_STAGES_FILE))
      File.write(PROGRESS_COMPLETED_STAGES_FILE, completed_stages.join(','))
    rescue StandardError => e
      UI.important("⚠️  Не удалось сохранить выполненные этапы в файл: #{e.message}")
    end

    current_stage = nil # Этап завершен, текущего этапа нет
  elsif status == 'start'
    current_stage = stage_name # Этап начался
  else
    current_stage = nil # Ошибка или другой статус
  end

  # Формируем заголовок
  if status == 'error'
    title = "❌ Ошибка: #{stage_name}"
  elsif status == 'success'
    title = "✅ #{stage_name} завершен"
  else
    title = '🚀 Pipeline выполняется'
  end

  # Формируем прогресс-бар
  progress_bar = format_stages_progress(all_stages, completed_stages, current_stage)

  # Формируем сообщение
  message = "<b>#{title}</b>\n"
  message += "━━━━━━━━━━━━━━━━━━━━\n\n"

  # Добавляем краткую информацию
  version_entry = details.detect { |key, _| key.to_s.downcase.match?(/версия|version/) }
  build_entry = details.detect { |key, _| key.to_s.downcase.match?(/build|сборка/) }
  target_entry = details.detect { |key, _| key.to_s.downcase.match?(/target|таргет/) }

  summary_parts = []
  summary_parts << "🎯 #{target_entry[1]}" if target_entry
  summary_parts << "📱 v#{version_entry[1]}" if version_entry
  summary_parts << "🔢 b#{build_entry[1]}" if build_entry
  message += "#{summary_parts.join(' • ')}\n\n" unless summary_parts.empty?

  # Добавляем прогресс-бар
  message += "<b>📊 Прогресс:</b>\n"
  message += "#{progress_bar}\n\n"

  # Загружаем сохраненные детали всех этапов
  all_stages_details = {}
  if File.exist?(PROGRESS_STAGES_DETAILS_FILE)
    begin
      all_stages_details = JSON.parse(File.read(PROGRESS_STAGES_DETAILS_FILE))
    rescue StandardError => e
      UI.important("⚠️  Не удалось прочитать детали этапов: #{e.message}")
      all_stages_details = {}
    end
  end

  # Сохраняем детали текущего этапа, если он успешно завершен
  if status == 'success' && details.any?
    # Фильтруем детали, исключая базовые поля
    stage_details = {}
    details.each do |key, value|
      next if key.to_s.downcase.match?(/версия|version|build|target|lane/)

      formatted_value = if value.is_a?(Float)
                          value.round(2).to_s
                        elsif value.is_a?(Array)
                          value.join(', ')
                        else
                          value.to_s
                        end
      stage_details[key] = formatted_value
    end

    # Сохраняем детали этапа только если есть что сохранить
    if stage_details.any?
      all_stages_details[stage_name] = stage_details

      # Сохраняем в файл
      begin
        FileUtils.mkdir_p(File.dirname(PROGRESS_STAGES_DETAILS_FILE))
        File.write(PROGRESS_STAGES_DETAILS_FILE, JSON.pretty_generate(all_stages_details))
      rescue StandardError => e
        UI.important("⚠️  Не удалось сохранить детали этапов: #{e.message}")
      end
    end
  end

  # Добавляем детали всех завершенных этапов
  if all_stages_details.any?
    message += "<b>📋 Детали этапов:</b>\n\n"

    all_stages.each do |stage|
      if all_stages_details.key?(stage) && all_stages_details[stage].any?
        message += "<b>✅ #{stage}:</b>\n"
        all_stages_details[stage].each do |key, value|
          message += "  • <b>#{key}:</b> <code>#{value}</code>\n"
        end
        message += "\n"
      end
    end
  end

  # Не показываем финальное сообщение здесь - оно будет отправлено отдельно
  # через send_final_telegram_message когда все этапы завершены

  # Добавляем ошибку, если есть
  if status == 'error' && error_message
    message += "<b>❌ Ошибка:</b>\n"
    error_msg = error_message[0..200] + '...' if error_message.length > 200
    message += "<code>#{error_msg || error_message}</code>\n\n"
  end

  # Добавляем метрики времени, если доступны
  if defined?($current_metrics) && $current_metrics && $current_metrics.metrics[:duration_formatted]
    message += "<b>⏱️ Время выполнения:</b> #{$current_metrics.metrics[:duration_formatted]}\n\n"
  end

  # Добавляем ссылку на pipeline
  pipeline_url = get_pipeline_url
  message += "🔗 <a href=\"#{pipeline_url}\">Открыть Pipeline</a>\n" if pipeline_url

  # Если message_id найден - ВСЕГДА обновляем существующее сообщение
  if message_id
    # Обновляем существующее сообщение
    success = edit_telegram_message(message_id, message, bot_token: bot_token, chat_id: chat_id)
    if success
      UI.message("📝 Обновлено прогресс-сообщение (ID: #{message_id})")
      return message_id
    else
      UI.important('⚠️  Не удалось обновить сообщение, попробуем создать новое')
      # Если не удалось обновить, попробуем создать новое
      message_id = nil
    end
  end

  # Создаем новое сообщение только если message_id не найден или обновление не удалось
  unless message_id
    # Создаем новое сообщение
    uri = URI("https://api.telegram.org/bot#{bot_token}/sendMessage")
    params = {
      chat_id: chat_id,
      text: message,
      parse_mode: 'HTML',
      disable_notification: false
    }

    begin
      http = Net::HTTP.new(uri.host, uri.port)
      http.use_ssl = true
      http.read_timeout = 10
      http.open_timeout = 10

      request = Net::HTTP::Post.new(uri.path)
      request.set_form_data(params)

      response = http.request(request)

      if response.code == '200'
        result = JSON.parse(response.body)
        new_message_id = result['result']['message_id']

        # ВАЖНО: Сохраняем message_id сразу после создания сообщения
        # Это гарантирует, что следующий этап сможет обновить это же сообщение
        save_progress_message_id(new_message_id)

        UI.success("📝 Создано новое прогресс-сообщение (ID: #{new_message_id})")
        UI.message('💾 message_id сохранен для использования в следующих этапах')

        # Проверяем, что файл действительно создан
        if File.exist?(PROGRESS_MESSAGE_ID_FILE)
          UI.success("✅ Файл #{PROGRESS_MESSAGE_ID_FILE} успешно создан")
        else
          UI.important("⚠️  Файл #{PROGRESS_MESSAGE_ID_FILE} не найден после сохранения!")
        end

        new_message_id
      else
        UI.important("⚠️  Не удалось создать сообщение в Telegram: #{response.code}")
        UI.message("Ответ: #{response.body}")
        nil
      end
    rescue StandardError => e
      UI.important("⚠️  Ошибка при создании сообщения в Telegram: #{e.message}")
      nil
    end
  end
end

# Отправляет уведомление о стадии процесса в Telegram
#
# @param title [String] заголовок уведомления о стадии
# @param details [Hash] детали стадии
# @param include_pipeline_link [Boolean] включать ли ссылку на pipeline
def notify_telegram_stage(title, details = {}, include_pipeline_link: true)
  # Если включен режим прогресс-сообщения, используем его
  if ENV['TELEGRAM_PROGRESS_MODE'] == 'true'
    UI.message('🔄 Режим прогресс-сообщения: обновляем существующее сообщение для этапа')
    lane_name = defined?($current_metrics) && $current_metrics ? $current_metrics.lane_name : nil
    stage_name = lane_name ? get_current_stage_name(lane_name) : title

    # Обновляем прогресс-сообщение (НЕ создаем новое!)
    update_telegram_progress(stage_name, status: 'start', details: details)
  else
    # Старый режим: отдельные сообщения
    UI.message('📨 Старый режим: отправляем отдельное сообщение для этапа')
    enhanced_details = details.dup
    if defined?($current_metrics) && $current_metrics && $current_metrics.lane_name
      enhanced_details['Lane'] = $current_metrics.lane_name unless enhanced_details.key?('Lane')
    end

    message = format_telegram_message("🔄 #{title}", enhanced_details, include_pipeline_link: include_pipeline_link)
    send_telegram_notification(message)
  end
end

# Отправляет уведомление об успехе в Telegram с автоматическим включением метрик
#
# @param title [String] заголовок уведомления
# @param details [Hash] детали (версия, build, время и т.д.)
# @param include_pipeline_link [Boolean] включать ли ссылку на pipeline
# @param include_metrics [Boolean] включать ли метрики в сообщение (по умолчанию true)
def notify_telegram_success(title, details = {}, include_pipeline_link: true, include_metrics: true)
  # Добавление дополнительной информации, если доступна
  enhanced_details = details.dup

  # Добавление информации о lane, если доступна
  if defined?($current_metrics) && $current_metrics && $current_metrics.lane_name
    enhanced_details['Lane'] = $current_metrics.lane_name unless enhanced_details.key?('Lane')
  end

  # Добавление метрик, если они доступны и включены
  if include_metrics && defined?($current_metrics) && $current_metrics
    # Завершаем метрики, если еще не завершены
    $current_metrics.finish unless $current_metrics.end_time

    # Добавляем время выполнения
    if $current_metrics.metrics[:duration_formatted]
      enhanced_details['Время выполнения'] = $current_metrics.metrics[:duration_formatted]
    end

    # Добавляем дополнительные метрики из объекта метрик
    metrics_data = $current_metrics.format_metrics_for_telegram
    metrics_data.each do |key, value|
      # Пропускаем уже добавленные поля и базовые поля, которые уже есть в details
      next if enhanced_details.key?(key) || key == 'Lane' || key == 'Duration'

      # Добавляем только полезные метрики
      if key.match?(/size|размер|ipa|dsym|uploaded|status|error/i)
        enhanced_details[key] = value
      end
    end
  end

  # Если включен режим прогресс-сообщения, используем его
  if ENV['TELEGRAM_PROGRESS_MODE'] == 'true'
    UI.message('🔄 Режим прогресс-сообщения: обновляем существующее сообщение')
    lane_name = defined?($current_metrics) && $current_metrics ? $current_metrics.lane_name : nil
    stage_name = lane_name ? get_current_stage_name(lane_name) : title

    # Обновляем прогресс-сообщение с текущим этапом (НЕ создаем новое!)
    update_telegram_progress(stage_name, status: 'success', details: enhanced_details)

    # Проверяем, все ли этапы завершены
    all_stages = get_pipeline_stages
    completed_stages = []
    if ENV['TELEGRAM_COMPLETED_STAGES']
      completed_stages = ENV['TELEGRAM_COMPLETED_STAGES'].split(',').map(&:strip)
    end
    if File.exist?(PROGRESS_COMPLETED_STAGES_FILE)
      begin
        file_stages = File.read(PROGRESS_COMPLETED_STAGES_FILE).strip.split(',').map(&:strip).reject(&:empty?)
        completed_stages = (completed_stages + file_stages).uniq
      rescue StandardError
        # Игнорируем ошибки чтения
      end
    end

    UI.message("📊 Завершено этапов: #{completed_stages.length}/#{all_stages.length}")

    # Если все этапы завершены, отправляем отдельное финальное сообщение
    if completed_stages.length >= all_stages.length
      UI.message('🎉 Все этапы завершены! Отправляем финальное сообщение...')
      send_final_telegram_message('success', enhanced_details, include_pipeline_link: include_pipeline_link)
    else
      UI.message('⏳ Еще остались незавершенные этапы, финальное сообщение будет отправлено позже')
    end
  else
    # Старый режим: отдельные сообщения
    UI.message('📨 Старый режим: отправляем отдельное сообщение')
    message = format_telegram_message("✅ #{title}", enhanced_details, include_pipeline_link: include_pipeline_link)
    send_telegram_notification(message)
  end
end

# Маскирует секреты в произвольном тексте перед отправкой во внешние системы (Telegram).
#
# Заменяет:
#   - значения известных секретных ENV-переменных (если они заданы), встречающиеся в тексте;
#   - строки, похожие на Telegram bot token (формат "123456789:AAExxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx").
#
# @param text [String] исходный текст
# @return [String] текст с замаскированными секретами
def sanitize_secrets(text)
  sanitized = text.to_s

  secret_env_keys = %w[TELEGRAM_BOT_TOKEN APPSTORE_KEY_CONTENT MATCH_PASSWORD APPMETRICA_KEY]
  secret_env_keys.each do |key|
    value = ENV[key]
    next if value.nil? || value.to_s.strip.empty?

    sanitized = sanitized.gsub(value, '***')
  end

  # Telegram bot token: "123456789:AAExxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
  sanitized = sanitized.gsub(/[0-9]{6,10}:[A-Za-z0-9_-]{30,}/, '***')

  sanitized
end

# Отправляет уведомление об ошибке в Telegram
#
# Ошибки ВСЕГДА отправляются отдельным сообщением с максимально детальным описанием,
# независимо от режима прогресс-сообщения.
#
# @param title [String] заголовок уведомления
# @param error [Exception] ошибка
# @param details [Hash] дополнительные детали
# @param include_pipeline_link [Boolean] включать ли ссылку на pipeline
def notify_telegram_error(title, error, details = {}, include_pipeline_link: true)
  error_details = details.dup

  # Полное сообщение об ошибке (без ограничений), с маскировкой секретов
  error_message = sanitize_secrets(error.message.to_s)
  error_details['Сообщение об ошибке'] = error_message

  # Добавление типа ошибки
  error_details['Тип ошибки'] = error.class.name

  # Добавление backtrace (стек вызовов) для детальной диагностики
  if error.respond_to?(:backtrace) && error.backtrace
    # Берем первые 20 строк backtrace для читаемости
    backtrace_lines = error.backtrace.first(20)
    if backtrace_lines.any?
      error_details['Стек вызовов'] = sanitize_secrets(backtrace_lines.join("\n"))
    end
  end

  # Добавление времени выполнения, если доступны метрики
  if defined?($current_metrics) && $current_metrics && $current_metrics.metrics[:duration_formatted]
    error_details['Время до ошибки'] = $current_metrics.metrics[:duration_formatted]
  end

  # Добавление информации о lane
  if defined?($current_metrics) && $current_metrics && $current_metrics.lane_name
    error_details['Lane'] = $current_metrics.lane_name
  end

  # Добавление информации о текущем этапе, если доступна
  if ENV['TELEGRAM_PROGRESS_MODE'] == 'true'
    lane_name = defined?($current_metrics) && $current_metrics ? $current_metrics.lane_name : nil
    if lane_name
      stage_name = get_current_stage_name(lane_name)
      error_details['Этап'] = stage_name
    end
  end

  # Добавление информации о проекте и CI/CD
  if ENV['CI_PROJECT_NAME'] || ENV['GITHUB_REPOSITORY']
    error_details['Проект'] = ENV['CI_PROJECT_NAME'] || ENV['GITHUB_REPOSITORY'] || 'не указан'
  end

  if ENV['CI_PIPELINE_IID'] || ENV['GITHUB_RUN_ID']
    error_details['Pipeline ID'] = ENV['CI_PIPELINE_IID'] || ENV['GITHUB_RUN_ID'] || 'не указан'
  end

  # Добавление времени возникновения ошибки
  error_details['Время ошибки'] = Time.now.strftime('%Y-%m-%d %H:%M:%S')

  # Формируем детальное сообщение об ошибке
  message = "<b>❌ #{title}</b>\n"
  message += "━━━━━━━━━━━━━━━━━━━━\n\n"

  # Добавляем краткую информацию
  version_entry = error_details.detect { |key, _| key.to_s.downcase.match?(/версия|version/) }
  build_entry = error_details.detect { |key, _| key.to_s.downcase.match?(/build|сборка/) }
  target_entry = error_details.detect { |key, _| key.to_s.downcase.match?(/target|таргет/) }

  summary_parts = []
  summary_parts << "🎯 #{target_entry[1]}" if target_entry
  summary_parts << "📱 v#{version_entry[1]}" if version_entry
  summary_parts << "🔢 b#{build_entry[1]}" if build_entry
  message += "#{summary_parts.join(' • ')}\n\n" unless summary_parts.empty?

  # Добавляем основную информацию об ошибке
  message += "<b>❌ Детали ошибки:</b>\n"
  message += "<b>Тип:</b> <code>#{error_details['Тип ошибки']}</code>\n"
  message += "<b>Сообщение:</b>\n<code>#{escape_html(error_details['Сообщение об ошибке'])}</code>\n\n"

  # Добавляем остальные детали
  error_details.each do |key, value|
    # Пропускаем уже добавленные поля
    next if key.to_s.downcase.match?(/тип ошибки|сообщение об ошибке|версия|version|build|target|таргет/)

    formatted_value = if value.is_a?(Array)
                        value.join("\n")
                      else
                        value.to_s
                      end

    # Для длинных значений (например, backtrace) используем code блок
    if formatted_value.length > 100 || formatted_value.include?("\n")
      message += "<b>#{key}:</b>\n<code>#{escape_html(formatted_value)}</code>\n\n"
    else
      message += "<b>#{key}:</b> <code>#{escape_html(formatted_value)}</code>\n"
    end
  end

  # Добавляем ссылку на pipeline (если включено)
  if include_pipeline_link
    pipeline_url = get_pipeline_url
    message += "\n🔗 <a href=\"#{pipeline_url}\">Открыть Pipeline</a>\n" if pipeline_url
  end

  # ВСЕГДА отправляем отдельное сообщение об ошибке
  # Это важно для быстрого обнаружения и диагностики проблем
  send_telegram_notification(message, disable_notification: false)
end

# Отправляет финальное сообщение о результате выполнения pipeline
#
# Отправляется отдельным сообщением когда все этапы завершены (успех или ошибка)
#
# @param result [String] результат: 'success' или 'error'
# @param details [Hash] детали всех этапов
# @param include_pipeline_link [Boolean] включать ли ссылку на pipeline
def send_final_telegram_message(result, details = {}, include_pipeline_link: true)
  return nil unless ENV['TELEGRAM_ENABLED'] == 'true'

  bot_token = ENV['TELEGRAM_BOT_TOKEN']
  chat_id = ENV['TELEGRAM_CHAT_ID']

  return nil if bot_token.nil? || bot_token.empty? || chat_id.nil? || chat_id.empty?

  # Получаем все этапы и их детали
  all_stages = get_pipeline_stages

  # Загружаем детали всех этапов
  all_stages_details = {}
  if File.exist?(PROGRESS_STAGES_DETAILS_FILE)
    begin
      all_stages_details = JSON.parse(File.read(PROGRESS_STAGES_DETAILS_FILE))
    rescue StandardError
      all_stages_details = {}
    end
  end

  # Формируем заголовок
  if result == 'success'
    title = '🎉 Pipeline выполнен успешно'
    emoji = '✅'
  else
    title = '❌ Pipeline завершен с ошибкой'
    emoji = '❌'
  end

  # Формируем сообщение
  message = "<b>#{emoji} #{title}</b>\n"
  message += "━━━━━━━━━━━━━━━━━━━━\n\n"

  # Добавляем краткую информацию
  version_entry = details.detect { |key, _| key.to_s.downcase.match?(/версия|version/) }
  build_entry = details.detect { |key, _| key.to_s.downcase.match?(/build|сборка/) }
  target_entry = details.detect { |key, _| key.to_s.downcase.match?(/target|таргет/) }

  summary_parts = []
  summary_parts << "🎯 #{target_entry[1]}" if target_entry
  summary_parts << "📱 v#{version_entry[1]}" if version_entry
  summary_parts << "🔢 b#{build_entry[1]}" if build_entry
  message += "#{summary_parts.join(' • ')}\n\n" unless summary_parts.empty?

  # Добавляем итоговый прогресс
  message += "<b>📊 Итоговый статус этапов:</b>\n"
  all_stages.each do |stage|
    if all_stages_details.key?(stage)
      message += "✅ #{stage}\n"
    else
      message += "❌ #{stage} (не выполнен)\n" if result == 'error'
      message += "⏳ #{stage} (не выполнен)\n" if result == 'success'
    end
  end
  message += "\n"

  # Добавляем детали всех завершенных этапов
  if all_stages_details.any?
    message += "<b>📋 Детали всех этапов:</b>\n\n"

    all_stages.each do |stage|
      if all_stages_details.key?(stage) && all_stages_details[stage].any?
        message += "<b>✅ #{stage}:</b>\n"
        all_stages_details[stage].each do |key, value|
          message += "  • <b>#{key}:</b> <code>#{escape_html(value.to_s)}</code>\n"
        end
        message += "\n"
      end
    end
  end

  # Добавляем общее время выполнения, если доступно
  if defined?($current_metrics) && $current_metrics && $current_metrics.metrics[:duration_formatted]
    message += "<b>⏱️ Общее время выполнения:</b> #{$current_metrics.metrics[:duration_formatted]}\n\n"
  end

  # Добавляем ссылку на pipeline
  if include_pipeline_link
    pipeline_url = get_pipeline_url
    message += "🔗 <a href=\"#{pipeline_url}\">Открыть Pipeline</a>\n" if pipeline_url
  end

  # Отправляем отдельное финальное сообщение
  send_telegram_notification(message, disable_notification: false)
end

# Экранирует HTML специальные символы
#
# @param text [String] текст для экранирования
# @return [String] экранированный текст
def escape_html(text)
  text.to_s
      .gsub('&', '&amp;')
      .gsub('<', '&lt;')
      .gsub('>', '&gt;')
      .gsub('"', '&quot;')
      .gsub("'", '&#39;')
end

