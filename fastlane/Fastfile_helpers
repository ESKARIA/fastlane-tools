# Класс для сбора метрик выполнения lanes
class FastlaneMetrics
  attr_accessor :start_time, :end_time, :lane_name, :metrics

  def initialize(lane_name)
    @lane_name = lane_name
    @start_time = Time.now
    @end_time = nil
    @metrics = {}

    # Автоматическое добавление базовой контекстной информации
    add_context_metrics
  end

  # Добавляет базовую контекстную информацию о проекте
  def add_context_metrics
    # Информация о проекте
    project_name = ENV['CI_PROJECT_NAME'] || ENV['GITHUB_REPOSITORY'] || ENV['CI_PROJECT_PATH'] || 'не указан'
    @metrics[:project] = project_name

    # Target приложения
    if defined?(MAIN_TARGET) && MAIN_TARGET
      @metrics[:target] = MAIN_TARGET.to_s
    elsif ENV['MAIN_TARGET']
      @metrics[:target] = ENV['MAIN_TARGET']
    end

    # Версия приложения
    @metrics[:version] = ENV['APP_VERSION'] if ENV['APP_VERSION'] && !ENV['APP_VERSION'].empty?

    # Build number
    if defined?(BUILD_NUMBER) && BUILD_NUMBER
      @metrics[:build_number] = BUILD_NUMBER.to_s
    elsif ENV['CI_PIPELINE_IID']
      @metrics[:build_number] = ENV['CI_PIPELINE_IID']
    elsif ENV['BUILD_NUMBER']
      @metrics[:build_number] = ENV['BUILD_NUMBER']
    end

    # CI/CD система
    @metrics[:ci_system] = if ENV['CI']
                             if ENV['CI_PIPELINE_URL'] || ENV['CI_JOB_URL']
                               'GitLab CI'
                             elsif ENV['GITHUB_SERVER_URL']
                               'GitHub Actions'
                             elsif ENV['BUILD_URL'] || ENV['JOB_URL']
                               'Jenkins'
                             else
                               'CI/CD'
                             end
                           else
                             'Local'
                           end

    # Pipeline URL (если доступен)
    # Вызываем глобальную функцию get_pipeline_url
    begin
      # Функция определена в том же файле, поэтому доступна в контексте
      pipeline_url = get_pipeline_url
      @metrics[:pipeline_url] = pipeline_url if pipeline_url
    rescue StandardError
      # Если функция недоступна, просто пропускаем
    end

    # Pipeline ID
    if ENV['CI_PIPELINE_IID']
      @metrics[:pipeline_id] = ENV['CI_PIPELINE_IID']
    elsif ENV['GITHUB_RUN_ID']
      @metrics[:pipeline_id] = ENV['GITHUB_RUN_ID']
    elsif ENV['BUILD_NUMBER']
      @metrics[:pipeline_id] = ENV['BUILD_NUMBER']
    end
  end

  # Добавляет метрику
  def add_metric(key, value)
    @metrics[key] = value
  end

  # Завершает сбор метрик
  def finish
    @end_time = Time.now
    @metrics[:duration_seconds] = (@end_time - @start_time).round(2)
    @metrics[:duration_formatted] = format_duration(@metrics[:duration_seconds])
  end

  # Форматирует длительность в читаемый вид
  def format_duration(seconds)
    if seconds < 60
      "#{seconds.round(1)} сек"
    elsif seconds < 3600
      minutes = (seconds / 60).floor
      secs = (seconds % 60).round
      "#{minutes} мин #{secs} сек"
    else
      hours = (seconds / 3600).floor
      minutes = ((seconds % 3600) / 60).floor
      "#{hours} ч #{minutes} мин"
    end
  end

  # Выводит метрики в консоль
  def print
    UI.header("📊 Метрики выполнения: #{@lane_name}")

    # Группировка метрик по категориям для лучшей читаемости
    context_metrics = {}
    custom_metrics = {}
    time_metrics = {}

    @metrics.each do |key, value|
      case key.to_s
      when /^(project|target|version|build_number|ci_system|pipeline|app_identifier)$/
        context_metrics[key] = value
      when /^(duration|time)/
        time_metrics[key] = value
      else
        custom_metrics[key] = value
      end
    end

    # Вывод контекстной информации
    unless context_metrics.empty?
      UI.message('📋 Контекст:')
      context_metrics.each do |key, value|
        UI.message("  #{format_metric_key(key)}: #{value}")
      end
    end

    # Вывод временных метрик
    unless time_metrics.empty?
      UI.message('⏱️  Время выполнения:')
      time_metrics.each do |key, value|
        UI.message("  #{format_metric_key(key)}: #{value}")
      end
    end

    # Вывод пользовательских метрик
    return if custom_metrics.empty?

    UI.message('📈 Дополнительные метрики:')
    custom_metrics.each do |key, value|
      UI.message("  #{format_metric_key(key)}: #{value}")
    end
  end

  # Форматирует ключ метрики для вывода
  def format_metric_key(key)
    key.to_s.gsub('_', ' ').split.map(&:capitalize).join(' ')
  end

  # Возвращает метрики в виде строки для Telegram
  def to_telegram_message
    format_telegram_message(
      "📊 Метрики: #{@lane_name}",
      format_metrics_for_telegram,
      include_pipeline_link: !!@metrics[:pipeline_url],
      pipeline_url: @metrics[:pipeline_url]
    )
  end

  def format_metrics_for_telegram
    # Переводим базовые метрики в человекочитаемый вид
    metric_details = {}

    {
      'Project' => @metrics[:project],
      'Target' => @metrics[:target],
      'Version' => @metrics[:version],
      'Build' => @metrics[:build_number],
      'CI' => @metrics[:ci_system],
      'Pipeline ID' => @metrics[:pipeline_id],
      'Duration (sec)' => @metrics[:duration_seconds],
      'Duration' => @metrics[:duration_formatted],
      'Start At' => @metrics[:start_time],
      'End At' => @metrics[:end_time]
    }.each do |label, value|
      next if value.nil? || value.to_s.empty?

      metric_details[label] = value
    end

    # Добавляем пользовательские метрики как есть
    custom_keys = @metrics.keys - %i[project target version build_number ci_system pipeline_id duration_seconds duration_formatted start_time end_time pipeline_url]
    custom_keys.each do |key|
      metric_details[format_metric_key(key)] = @metrics[key]
    end

    metric_details
  end

  # Сохраняет метрики в файл
  #
  # По умолчанию путь привязан к каталогу самого Fastfile_helpers (__dir__),
  # а не к Dir.pwd (который у fastlane равен папке fastlane/) — иначе
  # относительный 'fastlane/metrics.json' создаёт вложенную fastlane/fastlane/.
  def save_to_file(file_path = File.expand_path('metrics.json', __dir__))
    metrics_data = {
      lane: @lane_name,
      timestamp: @start_time.iso8601,
      end_time: @end_time&.iso8601,
      # Контекстная информация для удобного поиска
      context: {
        project: @metrics[:project],
        target: @metrics[:target],
        version: @metrics[:version],
        build_number: @metrics[:build_number],
        ci_system: @metrics[:ci_system],
        pipeline_id: @metrics[:pipeline_id]
      },
      metrics: @metrics
    }

    # Создание директории, если она не существует
    file_dir = File.dirname(file_path)
    FileUtils.mkdir_p(file_dir) unless File.directory?(file_dir)

    # Чтение существующих метрик
    existing_metrics = []
    if File.exist?(file_path)
      begin
        existing_metrics = JSON.parse(File.read(file_path))
      rescue StandardError
        existing_metrics = []
      end
    end

    # Добавление новых метрик
    existing_metrics << metrics_data

    # Сохранение (сохраняем только последние 100 записей)
    existing_metrics = existing_metrics.last(100)

    File.write(file_path, JSON.pretty_generate(existing_metrics))
    UI.message("📊 Метрики сохранены в #{file_path}")
  end
end

# Глобальная переменная для хранения метрик текущего lane
$current_metrics = nil

# Начинает сбор метрик для lane
#
# @param lane_name [String] название lane
# @return [FastlaneMetrics] объект метрик
def start_metrics(lane_name)
  $current_metrics = FastlaneMetrics.new(lane_name)
  $current_metrics
end

# Завершает сбор метрик и выводит их
#
# @param send_to_telegram [Boolean] отправлять ли метрики в Telegram отдельным сообщением
# @param save_to_file [Boolean] сохранять ли метрики в файл
# @note Метрики автоматически включаются в notify_telegram_success, поэтому обычно send_to_telegram должен быть false
def finish_metrics(send_to_telegram: false, save_to_file: true)
  return unless $current_metrics

  $current_metrics.finish
  $current_metrics.print

  $current_metrics.save_to_file if save_to_file

  # Отправка метрик отдельным сообщением только если явно запрошено
  # Обычно метрики включаются в финальное уведомление через notify_telegram_success
  if send_to_telegram
    message = $current_metrics.to_telegram_message
    send_telegram_notification(message)
  end

  $current_metrics
end

# Добавляет метрику к текущему объекту метрик
#
# @param key [String] название метрики
# @param value [Object] значение метрики
def add_metric(key, value)
  $current_metrics&.add_metric(key, value)
end

