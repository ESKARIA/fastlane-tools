# Подстроки ошибок TestFlight/App Store Connect, которые фактически означают,
# что операция уже выполнена (сборка уже загружена/отправлена/распределена),
# и поэтому не должны считаться сбоем и повторяться.
#
# Список — объединение (union) вариантов, ранее продублированных в:
#   - retry_with_backoff (этот файл)
#   - upload_testflight / upload_external_testflight (Fastfile_upload)
#   - mac_upload_with_retry (Fastfile_macos)
NON_RETRYABLE_TESTFLIGHT_ERRORS = [
  'already submitted for review',
  'cannot add internal group',
  'builds cannot be assigned',
  'already distributed',
  'build already exists'
].freeze

# Выполняет блок кода с повторными попытками при ошибках
#
# Повторяет попытки при ЛЮБЫХ ошибках (не только сетевых) — сетевые ошибки
# логируются с отдельной пометкой, но задержка и лимит попыток одинаковы для
# всех типов ошибок, кроме признанных «уже выполнено» (см. NON_RETRYABLE_TESTFLIGHT_ERRORS).
#
# @param max_retries [Integer] максимальное количество попыток (по умолчанию 3)
# @param delay [Float] задержка между попытками в секундах (по умолчанию 5)
# @param retryable_errors [Array<Class>] классы ошибок, при которых нужно повторять (по умолчанию все StandardError)
# @param block [Proc] блок кода для выполнения
# @return [Object] результат выполнения блока
#
# @example
#   result = retry_with_backoff(max_retries: 3, delay: 5) do
#     testflight(...)
#   end
def retry_with_backoff(max_retries: 3, delay: 5.0, retryable_errors: [StandardError], &block)
  attempts = 0

  begin
    attempts += 1
    UI.message("Попытка #{attempts}/#{max_retries}...") if attempts > 1
    block.call
  rescue *retryable_errors => e
    error_message = e.message.to_s.downcase

    # Если ошибка указывает на то, что операция уже выполнена, считаем успехом
    if NON_RETRYABLE_TESTFLIGHT_ERRORS.any? { |msg| error_message.include?(msg) }
      UI.success("✅ Операция уже выполнена: #{e.message}")
      return true
    end

    # Проверяем, является ли ошибка сетевой (требующей повторной попытки)
    if network_error?(e) && attempts < max_retries
      # Экспоненциальная задержка: delay * 2^(attempts-1)
      wait_time = delay * (2**(attempts - 1))
      UI.important("⚠️  Сетевая ошибка (попытка #{attempts}/#{max_retries}): #{e.message}")
      UI.message("Повторная попытка через #{wait_time.round(1)} секунд...")
      sleep(wait_time)
      retry
    elsif attempts < max_retries
      # Для других ошибок также повторяем, но с предупреждением
      wait_time = delay * (2**(attempts - 1))
      UI.important("⚠️  Ошибка (попытка #{attempts}/#{max_retries}): #{e.message}")
      UI.message("Повторная попытка через #{wait_time.round(1)} секунд...")
      sleep(wait_time)
      retry
    else
      UI.error("❌ Все #{max_retries} попыток исчерпаны")
      raise e
    end
  end
end

# Проверяет, является ли ошибка сетевой (требующей повторной попытки)
#
# @param error [Exception] ошибка для проверки
# @return [Boolean] true, если ошибка сетевого характера
def network_error?(error)
  network_error_messages = [
    'timeout',
    'connection',
    'network',
    'socket',
    'temporarily unavailable',
    'service unavailable',
    'bad gateway',
    'gateway timeout',
    'internal server error',
    'rate limit'
  ]

  error_message = error.message.downcase
  network_error_messages.any? { |msg| error_message.include?(msg) }
end

# Выполняет загрузку в TestFlight с retry-логикой и идемпотентной обработкой
# ошибок «уже выполнено» (см. NON_RETRYABLE_TESTFLIGHT_ERRORS).
#
# Общая логика, ранее продублированная в upload_testflight / upload_external_testflight
# (Fastfile_upload) и mac_upload_with_retry (Fastfile_macos):
#   - если доступен retry_with_backoff — используется он (повтор с задержкой на любых ошибках,
#     кроме признанных «уже выполнено», которые сразу считаются успехом);
#   - если retry_with_backoff недоступен — testflight выполняется один раз без повторов,
#     но с той же обработкой «уже выполнено» ошибок.
#
# @param testflight_params [Hash] параметры для action `testflight`
# @param max_retries [Integer] максимальное количество попыток (по умолчанию 3)
# @param delay [Float] задержка между попытками в секундах (по умолчанию 5)
# @return [Boolean] true, если загрузка выполнена успешно (в т.ч. если она уже была выполнена ранее)
# @raise [StandardError] если ошибка не входит в список «уже выполнено»
def upload_with_testflight_retry(testflight_params, max_retries: 3, delay: 5.0)
  upload_success = false

  already_done = lambda do |e|
    error_message = e.message.to_s.downcase
    NON_RETRYABLE_TESTFLIGHT_ERRORS.any? { |msg| error_message.include?(msg) }
  end

  if respond_to?(:retry_with_backoff)
    begin
      # retry_with_backoff может вернуть true сам по себе (кейс «уже выполнено»),
      # не выполнив блок до конца — поэтому используем и возвращаемое значение,
      # и флаг, выставляемый внутри блока при обычном успехе.
      result = retry_with_backoff(max_retries: max_retries, delay: delay) do
        testflight(**testflight_params)
        upload_success = true
      end
      upload_success ||= (result == true)
    rescue StandardError => e
      raise e unless already_done.call(e)

      UI.success("✅ Сборка уже загружена и обработана: #{e.message}")
      upload_success = true
    end
  else
    # Если retry логика недоступна, выполняем без повторов
    begin
      testflight(**testflight_params)
      upload_success = true
    rescue StandardError => e
      raise e unless already_done.call(e)

      UI.success("✅ Сборка уже загружена и обработана: #{e.message}")
      upload_success = true
    end
  end

  upload_success
end

