# LANES
# ==============================================================================

platform :mac do
  desc 'macOS Direct: сгенерировать Developer ID сертификаты (Application + Installer)'
  lane :match_generate_developer_id do |_options|
    macos_direct_generate_match
  end

  desc 'macOS Direct: установить Developer ID сертификаты (readonly)'
  lane :match_install_developer_id do |_options|
    macos_direct_install_match
  end

  desc 'macOS Direct: импортировать вручную выпущенный Developer ID сертификат ' \
       '(cert_path, p12_path, p12_password — опционально)'
  lane :match_import_developer_id do |options|
    macos_direct_import_certificate(
      cert_path: options[:cert_path] || ENV['DEVELOPER_ID_CERT_PATH'],
      p12_path: options[:p12_path] || ENV['DEVELOPER_ID_P12_PATH'],
      p12_password: options[:p12_password] || ENV['DEVELOPER_ID_P12_PASSWORD']
    )
  end

  desc 'macOS Direct: собрать .app с подписью Developer ID'
  lane :build_direct do |_options|
    macos_direct_build
  end

  desc 'macOS Direct: собрать .dmg из .app (app_path — опционально, иначе из lane_context)'
  lane :make_dmg do |options|
    macos_direct_make_dmg(app_path: options[:app_path])
  end

  desc 'macOS Direct: нотаризовать .dmg и staple тикет (dmg_path — опционально)'
  lane :notarize_dmg do |options|
    macos_direct_notarize(dmg_path: options[:dmg_path])
  end

  desc 'macOS Direct: сгенерировать appcast.xml (Sparkle, если задан SPARKLE_PRIVATE_KEY) и latest.json'
  lane :generate_appcast_feed do |options|
    macos_direct_generate_appcast(dmg_path: options[:dmg_path])
  end

  desc 'macOS Direct: полный релиз — build_direct → make_dmg → notarize_dmg → generate_appcast_feed'
  lane :release_direct do |_options|
    macos_direct_release
  end
end
